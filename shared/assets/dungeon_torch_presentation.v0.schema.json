{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/assets/dungeon_torch_presentation.v0.schema.json",
  "title": "Dungeon torch presentation (v0)",
  "description": "Client-only dungeon wall torch placement and lighting tuning.",
  "type": "object",
  "required": [
    "version",
    "enabled",
    "wall_segment_tiles",
    "torches_per_segment_min",
    "torches_per_segment_max",
    "wall_inset",
    "wall_end_margin",
    "max_shader_torches",
    "mount_height_fraction",
    "fog_light_radius",
    "torch_feather_world",
    "omni_light_enabled",
    "omni_range",
    "omni_energy",
    "light_color",
    "flame_color",
    "flame_emission_color",
    "flame_emission_energy"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "enabled": { "type": "boolean" },
    "wall_segment_tiles": { "type": "number", "exclusiveMinimum": 0 },
    "torches_per_segment_min": { "type": "integer", "minimum": 0, "maximum": 8 },
    "torches_per_segment_max": { "type": "integer", "minimum": 0, "maximum": 8 },
    "wall_inset": { "type": "number", "minimum": 0 },
    "wall_end_margin": { "type": "number", "minimum": 0 },
    "max_shader_torches": { "type": "integer", "minimum": 1, "maximum": 32 },
    "mount_height_fraction": { "type": "number", "exclusiveMinimum": 0, "maximum": 1.0 },
    "fog_light_radius": { "type": "number", "exclusiveMinimum": 0 },
    "torch_feather_world": { "type": "number", "minimum": 0 },
    "omni_light_enabled": { "type": "boolean" },
    "omni_range": { "type": "number", "exclusiveMinimum": 0 },
    "omni_energy": { "type": "number", "exclusiveMinimum": 0 },
    "light_color": { "type": "string", "minLength": 1 },
    "flame_color": { "type": "string", "minLength": 1 },
    "flame_emission_color": { "type": "string", "minLength": 1 },
    "flame_emission_energy": { "type": "number", "exclusiveMinimum": 0 },
    "flame_radius_top": { "type": "number", "exclusiveMinimum": 0 },
    "flame_radius_bottom": { "type": "number", "exclusiveMinimum": 0 },
    "flame_height": { "type": "number", "exclusiveMinimum": 0 },
    "bracket_width": { "type": "number", "exclusiveMinimum": 0 },
    "bracket_height": { "type": "number", "exclusiveMinimum": 0 }
  }
}
