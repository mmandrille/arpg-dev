{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/assets/movement_presentation.v0.schema.json",
  "title": "Movement presentation (v0)",
  "description": "Client-only movement presentation tuning. No gameplay authority.",
  "type": "object",
  "required": ["version", "tick_smoothing", "mobility_smoothing"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "tick_smoothing": {
      "type": "object",
      "required": ["enabled", "snapshot_interval_seconds", "snap_distance"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "snapshot_interval_seconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1.0,
          "description": "Interpolation duration between 10 Hz authoritative snapshots."
        },
        "snap_distance": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "World-units delta above which display snaps instead of lerping."
        },
        "projectiles_enabled": {
          "type": "boolean",
          "description": "When true, authoritative projectile entities use tick smoothing."
        },
        "projectile_snap_distance": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Snap threshold for fast-moving projectiles; defaults to snap_distance when omitted."
        },
        "loot_enabled": {
          "type": "boolean",
          "description": "When true, authoritative loot entities use tick smoothing."
        },
        "loot_snap_distance": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Snap threshold for loot nodes."
        },
        "interactables_enabled": {
          "type": "boolean",
          "description": "When true, authoritative interactable entities use tick smoothing."
        },
        "interactable_snap_distance": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Snap threshold for interactable nodes."
        }
      }
    },
    "mobility_smoothing": {
      "type": "object",
      "required": ["enabled", "teleport_duration_seconds", "teleport_travel_duration_seconds"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "teleport_duration_seconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1.0
        },
        "teleport_travel_duration_seconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 2.0
        }
      }
    }
  }
}
