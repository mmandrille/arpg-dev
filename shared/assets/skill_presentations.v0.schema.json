{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/assets/skill_presentations.v0.schema.json",
  "title": "Skill presentations (v0)",
  "description": "Client-facing skill labels and icons. Gameplay authority stays in shared/rules/skills.v0.json.",
  "type": "object",
  "required": ["version", "skills"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["icon", "summary"],
        "additionalProperties": false,
        "properties": {
          "icon": {
            "type": "object",
            "required": ["label", "shape", "color", "accent"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string", "minLength": 1, "maxLength": 3 },
              "shape": {
                "type": "string",
                "enum": [
                  "bolt",
                  "burst",
                  "heart",
                  "shield",
                  "slash",
                  "dash",
                  "flame",
                  "ice_spike",
                  "leap",
                  "orb_projectile",
                  "poison_dagger",
                  "quake",
                  "arrow",
                  "pin",
                  "volley",
                  "passive_arcane_focus",
                  "passive_mana_weaving",
                  "passive_spell_dynamo",
                  "passive_iron_hide",
                  "passive_battle_tempo",
                  "passive_crushing_force",
                  "passive_vigilant_guard",
                  "passive_faithful_bulwark",
                  "passive_consecrated_vitality",
                  "passive_quick_hands",
                  "passive_killer_instinct",
                  "passive_evasive_footwork",
                  "passive_trail_sense",
                  "passive_precision_draw",
                  "passive_deadeye"
                ]
              },
              "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
              "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
            }
          },
          "summary": { "type": "string", "minLength": 1 },
          "summary_key": { "type": "string", "minLength": 1 },
          "projectile_visual": { "type": "string", "minLength": 1 },
          "effect_visual": { "type": "string", "minLength": 1 },
          "visual_radius": { "type": "number", "exclusiveMinimum": 0 },
          "visual_duration": { "type": "number", "exclusiveMinimum": 0 },
          "visual_height": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
