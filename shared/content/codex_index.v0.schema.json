{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/content/codex_index.v0.schema.json",
  "title": "Compiled game codex index (v0)",
  "description": "Build output consumed by the Godot client. Generated by tools/content/build_codex.py.",
  "type": "object",
  "required": ["version", "chapters"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/chapter" }
    }
  },
  "$defs": {
    "chapter": {
      "type": "object",
      "required": ["id", "title", "pages"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "title": { "type": "string", "minLength": 1 },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/page" }
        }
      }
    },
    "page": {
      "type": "object",
      "required": ["id", "title", "sections"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/section" }
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "heading": { "type": "string" },
        "lines": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bullets": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
