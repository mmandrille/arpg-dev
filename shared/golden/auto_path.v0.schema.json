{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/auto_path.v0.schema.json",
  "title": "Auto path golden fixture (v0)",
  "type": "object",
  "required": ["version", "navigation", "cases"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 0 },
    "navigation": {
      "type": "object",
      "required": [
        "version",
        "cell_size",
        "max_auto_steps",
        "path_planning_horizon_seconds",
        "player_max_auto_steps",
        "player_path_nodes_per_search",
        "player_path_nodes_per_tick",
        "grid_bounds",
        "stop_distance",
        "monster_path_requests_per_tick",
        "monster_path_nodes_per_tick",
        "monster_path_cache_ticks",
        "monster_repath_throttle_ticks",
        "monster_repath_stagger_ticks",
        "monster_path_cache_goal_tolerance",
        "monster_movement_lod_min_live_monsters",
        "monster_movement_lod_near_distance",
        "monster_movement_lod_update_interval_ticks",
        "monster_overload_degrade_ticks",
        "monster_overload_live_monster_threshold"
      ],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "const": 0 },
        "cell_size": { "type": "number", "exclusiveMinimum": 0 },
        "max_auto_steps": { "type": "integer", "minimum": 1 },
        "path_planning_horizon_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "player_max_auto_steps": { "type": "integer", "minimum": 1 },
        "player_path_nodes_per_search": { "type": "integer", "minimum": 1 },
        "player_path_nodes_per_tick": { "type": "integer", "minimum": 1 },
        "grid_bounds": {
          "type": "object",
          "required": ["min_x", "min_y", "max_x", "max_y"],
          "additionalProperties": false,
          "properties": {
            "min_x": { "type": "integer" },
            "min_y": { "type": "integer" },
            "max_x": { "type": "integer" },
            "max_y": { "type": "integer" }
          }
        },
        "stop_distance": { "type": "number", "minimum": 0 },
        "monster_path_requests_per_tick": { "type": "integer", "minimum": 1 },
        "monster_path_nodes_per_search": { "type": "integer", "minimum": 1 },
        "monster_path_nodes_per_tick": { "type": "integer", "minimum": 1 },
        "monster_path_cache_ticks": { "type": "integer", "minimum": 0 },
        "monster_repath_throttle_ticks": { "type": "integer", "minimum": 0 },
        "monster_repath_stagger_ticks": { "type": "integer", "minimum": 1 },
        "monster_path_cache_goal_tolerance": { "type": "number", "minimum": 0 },
        "monster_movement_lod_min_live_monsters": { "type": "integer", "minimum": 1 },
        "monster_movement_lod_near_distance": { "type": "number", "minimum": 0 },
        "monster_movement_lod_update_interval_ticks": { "type": "integer", "minimum": 1 },
        "monster_overload_degrade_ticks": { "type": "integer", "minimum": 0 },
        "monster_overload_live_monster_threshold": { "type": "integer", "minimum": 0 }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "world_id", "goal_mode", "target_kind"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "world_id": { "type": "string", "minLength": 1 },
          "goal_mode": { "type": "string", "enum": ["point", "melee_approach"] },
          "target_kind": { "type": "string", "enum": ["monster", "loot", "interactable"] }
        }
      }
    }
  }
}
