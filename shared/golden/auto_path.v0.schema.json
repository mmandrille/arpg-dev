{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/auto_path.v0.schema.json",
  "title": "Auto path golden fixture (v0)",
  "type": "object",
  "required": ["version", "navigation", "cases"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 0 },
    "navigation": {
      "type": "object",
      "required": ["version", "cell_size", "max_auto_steps", "grid_bounds", "stop_distance"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "const": 0 },
        "cell_size": { "type": "number", "exclusiveMinimum": 0 },
        "max_auto_steps": { "type": "integer", "minimum": 1 },
        "grid_bounds": {
          "type": "object",
          "required": ["min_x", "min_y", "max_x", "max_y"],
          "additionalProperties": false,
          "properties": {
            "min_x": { "type": "integer" },
            "min_y": { "type": "integer" },
            "max_x": { "type": "integer" },
            "max_y": { "type": "integer" }
          }
        },
        "stop_distance": { "type": "number", "minimum": 0 }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "world_id", "start", "goal", "goal_mode", "target_kind", "unarmed_reach", "expected_step_count", "expected_end"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "world_id": { "type": "string", "minLength": 1 },
          "start": { "$ref": "#/$defs/vec2" },
          "goal": { "$ref": "#/$defs/vec2" },
          "goal_mode": { "type": "string", "enum": ["point", "melee_approach"] },
          "target_kind": { "type": "string", "enum": ["monster", "loot", "interactable"] },
          "unarmed_reach": { "type": "number", "exclusiveMinimum": 0 },
          "expected_step_count": { "type": "integer", "minimum": 0 },
          "expected_end": { "$ref": "#/$defs/vec2" }
        }
      }
    }
  },
  "$defs": {
    "vec2": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    }
  }
}
