{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/character_progression.v0.schema.json",
  "title": "Golden: character progression (v0)",
  "type": "object",
  "required": ["description", "base_stats", "points_per_level", "cases"],
  "additionalProperties": false,
  "properties": {
    "description": { "type": "string" },
    "base_stats": { "$ref": "#/$defs/base_stats" },
    "points_per_level": { "type": "integer", "minimum": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "experience", "base_stats", "starting_unspent_stat_points", "expected"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "experience": { "type": "integer", "minimum": 0 },
          "base_stats": { "$ref": "#/$defs/base_stats" },
          "starting_unspent_stat_points": { "type": "integer", "minimum": 0 },
          "allocated_stat": { "type": "string", "enum": ["str", "dex", "vit", "magic"] },
          "allocated_points": { "type": "integer", "minimum": 1 },
          "expected": {
            "type": "object",
            "required": ["level", "current_level_xp", "next_level_xp", "unspent_stat_points", "unspent_skill_points", "base_stats", "derived_stats"],
            "additionalProperties": false,
            "properties": {
              "level": { "type": "integer", "minimum": 1 },
              "current_level_xp": { "type": "integer", "minimum": 0 },
              "next_level_xp": { "type": "integer", "minimum": 0 },
              "unspent_stat_points": { "type": "integer", "minimum": 0 },
              "unspent_skill_points": { "type": "integer", "minimum": 0 },
              "base_stats": { "$ref": "#/$defs/base_stats" },
              "derived_stats": { "$ref": "#/$defs/derived_stats" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "base_stats": {
      "type": "object",
      "required": ["str", "dex", "vit", "magic"],
      "additionalProperties": false,
      "properties": {
        "str": { "type": "integer", "minimum": 1 },
        "dex": { "type": "integer", "minimum": 1 },
        "vit": { "type": "integer", "minimum": 1 },
        "magic": { "type": "integer", "minimum": 1 }
      }
    },
    "derived_stats": {
      "type": "object",
      "required": [
        "damage_min",
        "damage_max",
        "armor",
        "attack_speed",
        "attack_interval_ticks",
        "hit_chance",
        "crit_chance",
        "crit_damage",
        "movement_speed",
        "max_hp",
        "max_mana",
        "health_regen_per_second",
        "mana_regen_per_second"
      ],
      "additionalProperties": false,
      "properties": {
        "damage_min": { "type": "number" },
        "damage_max": { "type": "number" },
        "armor": { "type": "number" },
        "attack_speed": { "type": "number" },
        "attack_interval_ticks": { "type": "integer", "minimum": 1 },
        "hit_chance": { "type": "number" },
        "crit_chance": { "type": "number" },
        "crit_damage": { "type": "number" },
        "movement_speed": { "type": "number" },
        "max_hp": { "type": "number" },
        "max_mana": { "type": "number" },
        "health_regen_per_second": { "type": "number" },
        "mana_regen_per_second": { "type": "number" }
      }
    }
  }
}
