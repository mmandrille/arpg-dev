{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/coop_rewards_and_scaling.v0.schema.json",
  "title": "Co-op rewards and scaling golden fixture (v0)",
  "type": "object",
  "required": ["description", "xp_share", "party_challenge"],
  "additionalProperties": false,
  "properties": {
    "description": { "type": "string", "minLength": 1 },
    "xp_share": {
      "type": "object",
      "required": ["radius", "full_xp_per_eligible_player", "include_dead_players", "include_disconnected_players"],
      "additionalProperties": false,
      "properties": {
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "full_xp_per_eligible_player": { "type": "boolean" },
        "include_dead_players": { "type": "boolean" },
        "include_disconnected_players": { "type": "boolean" }
      }
    },
    "party_challenge": {
      "type": "object",
      "required": ["per_double_bonus", "max_bonus", "cases"],
      "additionalProperties": false,
      "properties": {
        "per_double_bonus": { "type": "number", "minimum": 0 },
        "max_bonus": { "type": "number", "minimum": 0 },
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["party_count", "expected_multiplier"],
            "additionalProperties": false,
            "properties": {
              "party_count": { "type": "integer", "minimum": 1 },
              "expected_multiplier": { "type": "number", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
