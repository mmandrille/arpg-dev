{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/damage_formula.v0.schema.json",
  "title": "Golden: damage formula (v0)",
  "type": "object",
  "required": ["description", "player_damage", "cases"],
  "additionalProperties": false,
  "properties": {
    "description": { "type": "string" },
    "player_damage": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["draw", "expected_damage"],
        "additionalProperties": false,
        "properties": {
          "draw": { "type": "integer", "minimum": 0 },
          "expected_damage": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
