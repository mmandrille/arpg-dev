{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/equipped_weapon_damage.v0.schema.json",
  "title": "Equipped weapon damage golden fixture (v0)",
  "type": "object",
  "required": ["description", "item_def_id", "damage", "cases"],
  "additionalProperties": false,
  "properties": {
    "description": { "type": "string", "minLength": 1 },
    "item_def_id": { "type": "string", "minLength": 1 },
    "damage": { "$ref": "#/$defs/damage_range" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["draw", "expected_damage"],
        "additionalProperties": false,
        "properties": {
          "draw": { "type": "integer", "minimum": 0 },
          "expected_damage": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "$defs": {
    "damage_range": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
