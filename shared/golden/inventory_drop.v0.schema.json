{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/inventory_drop.v0.schema.json",
  "title": "Inventory drop golden fixture (v0)",
  "type": "object",
  "required": ["version", "description", "world_id", "player_spawn", "item_def_id", "expected_loot_position", "constants"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 0 },
    "description": { "type": "string", "minLength": 1 },
    "world_id": { "type": "string", "minLength": 1 },
    "player_spawn": { "$ref": "#/$defs/vec2" },
    "item_def_id": { "type": "string", "minLength": 1 },
    "expected_loot_position": { "$ref": "#/$defs/vec2" },
    "constants": {
      "type": "object",
      "required": ["loot_drop_radius", "player_radius", "drop_step"],
      "additionalProperties": false,
      "properties": {
        "loot_drop_radius": { "type": "number", "exclusiveMinimum": 0 },
        "player_radius": { "type": "number", "exclusiveMinimum": 0 },
        "drop_step": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  },
  "$defs": {
    "vec2": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    }
  }
}
