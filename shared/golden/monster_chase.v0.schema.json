{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/monster_chase.v0.schema.json",
  "title": "Monster chase golden fixture (v0)",
  "type": "object",
  "required": ["version", "seed", "navigation", "cases"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "seed": { "type": "string", "minLength": 1 },
    "world_id": { "type": "string" },
    "navigation": {
      "type": "object",
      "required": [
        "version",
        "cell_size",
        "max_auto_steps",
        "grid_bounds",
        "stop_distance",
        "monster_path_requests_per_tick",
        "monster_path_nodes_per_tick",
        "monster_path_cache_ticks",
        "monster_repath_throttle_ticks",
        "monster_repath_stagger_ticks",
        "monster_movement_lod_min_live_monsters",
        "monster_movement_lod_near_distance",
        "monster_movement_lod_update_interval_ticks"
      ],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "integer", "const": 0 },
        "cell_size": { "type": "number", "exclusiveMinimum": 0 },
        "max_auto_steps": { "type": "integer", "minimum": 1 },
        "grid_bounds": {
          "type": "object",
          "required": ["min_x", "min_y", "max_x", "max_y"],
          "additionalProperties": false,
          "properties": {
            "min_x": { "type": "integer" },
            "min_y": { "type": "integer" },
            "max_x": { "type": "integer" },
            "max_y": { "type": "integer" }
          }
        },
        "stop_distance": { "type": "number", "minimum": 0 },
        "monster_path_requests_per_tick": { "type": "integer", "minimum": 1 },
        "monster_path_nodes_per_tick": { "type": "integer", "minimum": 1 },
        "monster_path_cache_ticks": { "type": "integer", "minimum": 0 },
        "monster_repath_throttle_ticks": { "type": "integer", "minimum": 0 },
        "monster_repath_stagger_ticks": { "type": "integer", "minimum": 1 },
        "monster_movement_lod_min_live_monsters": { "type": "integer", "minimum": 1 },
        "monster_movement_lod_near_distance": { "type": "number", "minimum": 0 },
        "monster_movement_lod_update_interval_ticks": { "type": "integer", "minimum": 1 }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "expected_events"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "world_id": { "type": "string" },
          "idle_player_ticks": { "type": "integer", "minimum": 0 },
          "player_kite_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["direction"],
              "additionalProperties": false,
              "properties": {
                "direction": {
                  "type": "object",
                  "required": ["x", "y"],
                  "additionalProperties": false,
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" }
                  }
                },
                "duration_ticks": { "type": "integer", "minimum": 1 },
                "ticks": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "wait_ticks_after_kite": { "type": "integer", "minimum": 0 },
          "expected_monster_position": {
            "type": "object",
            "required": ["x", "y"],
            "additionalProperties": false,
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          },
          "expected_monster_final_near_spawn": { "type": "boolean" },
          "expected_events": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
