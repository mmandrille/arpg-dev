{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/retaliation_damage.v0.schema.json",
  "title": "Golden: retaliation damage formula (v0)",
  "description": "Cross-language fixture for damage = min + (draw mod (max - min + 1)).",
  "type": "object",
  "required": ["retaliation_damage", "cases"],
  "additionalProperties": false,
  "properties": {
    "retaliation_damage": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["draw", "expected_damage"],
        "additionalProperties": false,
        "properties": {
          "draw": { "type": "integer", "minimum": 0 },
          "expected_damage": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
