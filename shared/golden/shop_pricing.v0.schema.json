{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/shop_pricing.v0.schema.json",
  "title": "Shop pricing golden fixture (v0)",
  "type": "object",
  "required": ["shop_id", "cases"],
  "additionalProperties": false,
  "properties": {
    "shop_id": { "type": "string" },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "input", "expected"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "input": {
            "type": "object",
            "required": ["item_def_id"],
            "additionalProperties": false,
            "properties": {
              "item_def_id": { "type": "string" },
              "item_template_id": { "type": "string" },
              "rarity": { "type": "string" },
              "rolled_stats": {
                "type": "object",
                "additionalProperties": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "expected": {
            "type": "object",
            "required": ["buy_price", "sell_price"],
            "additionalProperties": false,
            "properties": {
              "buy_price": { "type": "integer", "minimum": 1 },
              "sell_price": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
