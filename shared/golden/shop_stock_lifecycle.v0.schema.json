{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/shop_stock_lifecycle.v0.schema.json",
  "title": "Shop stock lifecycle golden fixture (v0)",
  "type": "object",
  "required": ["shop_id", "generated_stock", "finite_stock", "buyback"],
  "additionalProperties": false,
  "properties": {
    "shop_id": { "type": "string" },
    "generated_stock": {
      "type": "object",
      "required": ["offer_count", "source", "source_depth_policy", "refresh_on", "max_rarity", "cases"],
      "additionalProperties": false,
      "properties": {
        "offer_count": { "type": "integer", "minimum": 1 },
        "source": { "type": "string" },
        "source_depth_policy": { "type": "string" },
        "refresh_on": { "type": "string" },
        "max_rarity": { "type": "string" },
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "character_level", "deepest_dungeon_depth", "expected_min_source_depth", "expected_max_source_depth"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "character_level": { "type": "integer", "minimum": 1 },
              "deepest_dungeon_depth": { "type": "integer", "minimum": 0 },
              "expected_min_source_depth": { "type": "integer", "minimum": 1 },
              "expected_max_source_depth": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "finite_stock": {
      "type": "object",
      "required": ["initial_generated_count", "after_generated_purchase_count", "fixed_offer_count"],
      "additionalProperties": false,
      "properties": {
        "initial_generated_count": { "type": "integer", "minimum": 1 },
        "after_generated_purchase_count": { "type": "integer", "minimum": 0 },
        "fixed_offer_count": { "type": "integer", "minimum": 0 }
      }
    },
    "buyback": {
      "type": "object",
      "required": ["enabled", "offer_id", "scope", "sell_price", "buy_price", "buy_price_multiplier", "clear_on_leave_town", "persisted"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "offer_id": { "type": "string", "pattern": "^buyback:[a-z0-9_:-]+$" },
        "scope": { "type": "string" },
        "sell_price": { "type": "integer", "minimum": 1 },
        "buy_price": { "type": "integer", "minimum": 1 },
        "buy_price_multiplier": { "type": "number", "exclusiveMinimum": 0 },
        "clear_on_leave_town": { "type": "boolean" },
        "persisted": { "type": "boolean" }
      }
    }
  }
}
