{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/golden/slice_outcome.v0.schema.json",
  "title": "Golden: vertical-slice authoritative outcome (v0)",
  "description": "Expected authoritative end-state after the scripted slice flow (move -> attack until dead -> pickup -> equip) for the pinned seed. Consumed by the Go sim test.",
  "type": "object",
  "required": ["description", "pinned_seed", "monster_def_id", "dropped_item_def_id", "final_player_hp", "final_monster_hp", "final_inventory", "final_equipped"],
  "additionalProperties": false,
  "properties": {
    "description": { "type": "string" },
    "pinned_seed": { "type": "string", "minLength": 1 },
    "monster_def_id": { "type": "string" },
    "dropped_item_def_id": { "type": "string" },
    "final_player_hp": { "type": "integer", "minimum": 0 },
    "final_monster_hp": { "type": "integer", "minimum": 0 },
    "final_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_def_id", "slot", "equipped"],
        "additionalProperties": false,
        "properties": {
          "item_def_id": { "type": "string" },
          "slot": { "type": "string", "enum": ["weapon"] },
          "equipped": { "type": "boolean" }
        }
      }
    },
    "final_equipped": {
      "type": "object",
      "required": ["weapon"],
      "additionalProperties": false,
      "properties": {
        "weapon": { "type": ["string", "null"] }
      }
    }
  }
}
