{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/protocol/messages.v6.schema.json",
  "title": "Realtime messages (v6)",
  "description": "Validates a full realtime message: the common envelope plus a payload constrained by `type`. Session_snapshot and state_delta payload bodies have their own dedicated schemas; here they are checked only as objects.",
  "type": "object",
  "required": ["type", "message_id", "session_id", "tick", "payload"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "client_ready",
        "move_intent",
        "move_to_intent",
        "directional_attack_intent",
        "action_intent",
        "descend_intent",
        "ascend_intent",
        "teleport_intent",
        "equip_intent",
        "unequip_intent",
        "drop_intent",
        "use_intent",
        "assign_hotbar_intent",
        "use_hotbar_intent",
        "allocate_stat_intent",
        "allocate_skill_point_intent",
        "cast_skill_intent",
        "shop_buy_intent",
        "shop_sell_intent",
        "session_snapshot",
        "state_delta",
        "intent_accepted",
        "intent_rejected",
        "error"
      ]
    },
    "message_id": { "$ref": "#/$defs/prefixed_id" },
    "session_id": { "$ref": "#/$defs/prefixed_id" },
    "tick": { "type": "integer", "minimum": 0 },
    "correlation_id": { "$ref": "#/$defs/prefixed_id" },
    "payload": { "type": "object" }
  },
  "allOf": [
    { "if": { "properties": { "type": { "const": "client_ready" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/client_ready" } } } },
    { "if": { "properties": { "type": { "const": "move_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/move_intent" } } } },
    { "if": { "properties": { "type": { "const": "move_to_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/move_to_intent" } } } },
    { "if": { "properties": { "type": { "const": "directional_attack_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/directional_attack_intent" } } } },
    { "if": { "properties": { "type": { "const": "action_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/action_intent" } } } },
    { "if": { "properties": { "type": { "const": "descend_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/descend_intent" } } } },
    { "if": { "properties": { "type": { "const": "ascend_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/ascend_intent" } } } },
    { "if": { "properties": { "type": { "const": "teleport_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/teleport_intent" } } } },
    { "if": { "properties": { "type": { "const": "equip_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/equip_intent" } } } },
    { "if": { "properties": { "type": { "const": "unequip_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/unequip_intent" } } } },
    { "if": { "properties": { "type": { "const": "drop_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/drop_intent" } } } },
    { "if": { "properties": { "type": { "const": "use_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/use_intent" } } } },
    { "if": { "properties": { "type": { "const": "assign_hotbar_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/assign_hotbar_intent" } } } },
    { "if": { "properties": { "type": { "const": "use_hotbar_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/use_hotbar_intent" } } } },
    { "if": { "properties": { "type": { "const": "allocate_stat_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/allocate_stat_intent" } } } },
    { "if": { "properties": { "type": { "const": "allocate_skill_point_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/allocate_skill_point_intent" } } } },
    { "if": { "properties": { "type": { "const": "cast_skill_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/cast_skill_intent" } } } },
    { "if": { "properties": { "type": { "const": "shop_buy_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/shop_buy_intent" } } } },
    { "if": { "properties": { "type": { "const": "shop_sell_intent" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/shop_sell_intent" } } } },
    { "if": { "properties": { "type": { "const": "intent_accepted" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/intent_accepted" } } } },
    { "if": { "properties": { "type": { "const": "intent_rejected" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/intent_rejected" } } } },
    { "if": { "properties": { "type": { "const": "error" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/error" } } } }
  ],
  "$defs": {
    "prefixed_id": {
      "type": "string",
      "pattern": "^[a-z]+_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "decimal_id": {
      "type": "string",
      "description": "Authoritative entity / item-instance id as a decimal string (unsigned 64-bit, JSON-safe).",
      "pattern": "^[0-9]+$"
    },
    "vec2": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
    },
    "client_ready": {
      "type": "object",
      "required": ["client_version", "last_seen_tick"],
      "additionalProperties": false,
      "properties": {
        "client_version": { "type": "string" },
        "last_seen_tick": { "type": "integer", "minimum": 0 }
      }
    },
    "move_intent": {
      "type": "object",
      "required": ["direction", "duration_ticks"],
      "additionalProperties": false,
      "properties": {
        "direction": { "$ref": "#/$defs/vec2" },
        "duration_ticks": { "type": "integer", "minimum": 1 }
      }
    },
    "move_to_intent": {
      "type": "object",
      "required": ["position"],
      "additionalProperties": false,
      "properties": { "position": { "$ref": "#/$defs/vec2" } }
    },
    "directional_attack_intent": {
      "type": "object",
      "required": ["direction"],
      "additionalProperties": false,
      "properties": {
        "direction": { "$ref": "#/$defs/vec2" }
      }
    },
    "action_intent": {
      "type": "object",
      "required": ["target_id"],
      "additionalProperties": false,
      "properties": { "target_id": { "$ref": "#/$defs/decimal_id" } }
    },
    "descend_intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "ascend_intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "teleport_intent": {
      "type": "object",
      "required": ["target_level"],
      "additionalProperties": false,
      "properties": {
        "target_level": { "type": "integer", "maximum": 0 }
      }
    },
    "equip_intent": {
      "type": "object",
      "required": ["item_instance_id", "slot"],
      "additionalProperties": false,
      "properties": {
        "item_instance_id": { "$ref": "#/$defs/decimal_id" },
        "slot": { "$ref": "#/$defs/equipment_slot" }
      }
    },
    "unequip_intent": {
      "type": "object",
      "required": ["slot"],
      "additionalProperties": false,
      "properties": {
        "slot": { "$ref": "#/$defs/equipment_slot" }
      }
    },
    "drop_intent": {
      "type": "object",
      "required": ["item_instance_id"],
      "additionalProperties": false,
      "properties": {
        "item_instance_id": { "$ref": "#/$defs/decimal_id" }
      }
    },
    "use_intent": {
      "type": "object",
      "required": ["item_instance_id"],
      "additionalProperties": false,
      "properties": {
        "item_instance_id": { "$ref": "#/$defs/decimal_id" }
      }
    },
    "assign_hotbar_intent": {
      "type": "object",
      "required": ["slot_index", "item_instance_id"],
      "additionalProperties": false,
      "properties": {
        "slot_index": { "type": "integer", "minimum": 0, "maximum": 9 },
        "item_instance_id": {
          "oneOf": [
            { "$ref": "#/$defs/decimal_id" },
            { "type": "null" }
          ]
        }
      }
    },
    "use_hotbar_intent": {
      "type": "object",
      "required": ["slot_index"],
      "additionalProperties": false,
      "properties": {
        "slot_index": { "type": "integer", "minimum": 0, "maximum": 9 }
      }
    },
    "equipment_slot": {
      "type": "string",
      "enum": ["head", "amulet", "chest", "gloves", "belt", "boots", "ring_left", "ring_right", "main_hand", "off_hand"]
    },
    "allocate_stat_intent": {
      "type": "object",
      "required": ["stat", "points"],
      "additionalProperties": false,
      "properties": {
        "stat": { "type": "string", "enum": ["str", "dex", "vit", "magic"] },
        "points": { "type": "integer", "minimum": 1 }
      }
    },
    "allocate_skill_point_intent": {
      "type": "object",
      "required": ["skill_id"],
      "additionalProperties": false,
      "properties": {
        "skill_id": { "type": "string", "minLength": 1 }
      }
    },
    "cast_skill_intent": {
      "type": "object",
      "required": ["skill_id"],
      "additionalProperties": false,
      "properties": {
        "skill_id": { "type": "string", "minLength": 1 },
        "target_id": { "$ref": "#/$defs/decimal_id" },
        "direction": { "$ref": "#/$defs/vec2" }
      },
      "anyOf": [
        { "required": ["target_id"] },
        { "required": ["direction"] }
      ]
    },
    "shop_buy_intent": {
      "type": "object",
      "required": ["shop_entity_id", "offer_id"],
      "additionalProperties": false,
      "properties": {
        "shop_entity_id": { "$ref": "#/$defs/decimal_id" },
        "offer_id": { "type": "string", "pattern": "^(fixed|generated|buyback):[a-z0-9_:-]+$" }
      }
    },
    "shop_sell_intent": {
      "type": "object",
      "required": ["shop_entity_id", "item_instance_id"],
      "additionalProperties": false,
      "properties": {
        "shop_entity_id": { "$ref": "#/$defs/decimal_id" },
        "item_instance_id": { "$ref": "#/$defs/decimal_id" }
      }
    },
    "intent_accepted": {
      "type": "object",
      "required": ["accepted_message_id", "server_tick"],
      "additionalProperties": false,
      "properties": {
        "accepted_message_id": { "$ref": "#/$defs/prefixed_id" },
        "server_tick": { "type": "integer", "minimum": 0 }
      }
    },
    "intent_rejected": {
      "type": "object",
      "required": ["rejected_message_id", "reason"],
      "additionalProperties": false,
      "properties": {
        "rejected_message_id": { "$ref": "#/$defs/prefixed_id" },
        "reason": { "type": "string" }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
