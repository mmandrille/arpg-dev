{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/protocol/state_delta.v8.schema.json",
  "title": "state_delta payload (v8)",
  "description": "Ordered authoritative changes produced by a single tick, applied in array order. Unknown `op` values are protocol errors.",
  "type": "object",
  "required": ["server_tick", "level", "changes", "events"],
  "additionalProperties": false,
  "properties": {
    "server_tick": { "type": "integer", "minimum": 0 },
    "level": { "type": "integer" },
    "changes": { "type": "array", "items": { "$ref": "#/$defs/change" } },
    "events": { "type": "array", "items": { "$ref": "#/$defs/event" } }
  },
  "$defs": {
    "prefixed_id": { "type": "string", "pattern": "^[a-z]+_[0-9A-HJKMNP-TV-Z]{26}$" },
    "decimal_id": { "type": "string", "pattern": "^[0-9]+$" },
    "vec2": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
    },
    "positive_vec2": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": { "x": { "type": "number", "exclusiveMinimum": 0 }, "y": { "type": "number", "exclusiveMinimum": 0 } }
    },
    "wall": {
      "type": "object",
      "required": ["id", "position", "size"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
        "position": { "$ref": "#/$defs/vec2" },
        "size": { "$ref": "#/$defs/positive_vec2" },
        "source": { "type": "string", "enum": ["perimeter", "generated", "preset"] }
      }
    },
    "entity": {
      "type": "object",
      "required": ["id", "type", "position"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/decimal_id" },
        "type": { "type": "string", "enum": ["player", "monster", "loot", "interactable", "projectile"] },
        "position": { "$ref": "#/$defs/vec2" },
        "hp": { "type": "integer", "minimum": 0 },
        "max_hp": { "type": "integer", "minimum": 0 },
        "mana": { "type": "integer", "minimum": 0 },
        "max_mana": { "type": "integer", "minimum": 0 },
        "monster_def_id": { "type": "string" },
        "monster_pack_id": { "type": "string" },
        "monster_pack_leader": { "type": "boolean" },
        "character_id": { "$ref": "#/$defs/prefixed_id" },
        "item_def_id": { "type": "string" },
        "amount": { "type": "integer", "minimum": 1 },
        "item_template_id": { "type": "string" },
        "display_name": { "type": "string" },
        "rarity": { "type": "string" },
        "is_boss": { "type": "boolean" },
        "boss_template_id": { "type": "string" },
        "visual_model": { "type": "string" },
        "visual_scale": { "type": "number", "exclusiveMinimum": 0 },
        "visual_tint": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "boss_phase": { "$ref": "#/$defs/boss_phase" },
        "rolled_stats": { "$ref": "#/$defs/rolled_stats" },
        "requirements": { "$ref": "#/$defs/requirements" },
        "requirement_status": { "$ref": "#/$defs/requirement_status_list" },
        "requirements_met": { "type": "boolean" },
        "equip_preview": { "$ref": "#/$defs/equip_preview" },
        "effect_ids": { "$ref": "#/$defs/effect_ids" },
        "interactable_def_id": { "type": "string" },
        "elite_objective": { "type": "boolean" },
        "quest_reward": { "type": "boolean" },
        "corpse_character_id": { "$ref": "#/$defs/prefixed_id" },
        "corpse_name": { "type": "string" },
        "corpse_level": { "type": "integer", "minimum": 1 },
        "corpse_item_count": { "type": "integer", "minimum": 0 },
        "owner_id": { "$ref": "#/$defs/decimal_id" },
        "target_id": { "$ref": "#/$defs/decimal_id" },
        "projectile_def_id": { "type": "string" },
        "state": { "type": "string", "enum": ["closed", "open", "ready", "locked", "disabled"] }
      }
    },
    "item": {
      "type": "object",
      "required": ["item_instance_id", "item_def_id", "slot", "equipped"],
      "additionalProperties": false,
      "properties": {
        "item_instance_id": { "$ref": "#/$defs/decimal_id" },
        "item_def_id": { "type": "string" },
        "item_template_id": { "type": "string" },
        "display_name": { "type": "string" },
        "rarity": { "type": "string" },
        "rolled_stats": { "$ref": "#/$defs/rolled_stats" },
        "requirements": { "$ref": "#/$defs/requirements" },
        "requirement_status": { "$ref": "#/$defs/requirement_status_list" },
        "requirements_met": { "type": "boolean" },
        "equip_preview": { "$ref": "#/$defs/equip_preview" },
        "effect_ids": { "$ref": "#/$defs/effect_ids" },
        "slot": { "type": "string", "enum": ["", "head", "amulet", "chest", "gloves", "belt", "boots", "ring_left", "ring_right", "main_hand", "off_hand"] },
        "equipped": { "type": "boolean" }
      }
    },
    "weapon_set": {
      "type": "object",
      "required": ["index", "main_hand", "off_hand"],
      "additionalProperties": false,
      "properties": {
        "index": { "type": "integer", "minimum": 0, "maximum": 1 },
        "main_hand": { "oneOf": [ { "$ref": "#/$defs/decimal_id" }, { "type": "null" } ] },
        "off_hand": { "oneOf": [ { "$ref": "#/$defs/decimal_id" }, { "type": "null" } ] }
      }
    },
    "stash_item": {
      "type": "object",
      "required": ["stash_item_id", "item_def_id"],
      "additionalProperties": false,
      "properties": {
        "stash_item_id": { "$ref": "#/$defs/decimal_id" },
        "item_def_id": { "type": "string" },
        "item_template_id": { "type": "string" },
        "display_name": { "type": "string" },
        "rarity": { "type": "string" },
        "rolled_stats": { "$ref": "#/$defs/rolled_stats" },
        "requirements": { "$ref": "#/$defs/requirements" },
        "requirement_status": { "$ref": "#/$defs/requirement_status_list" },
        "requirements_met": { "type": "boolean" },
        "equip_preview": { "$ref": "#/$defs/equip_preview" },
        "effect_ids": { "$ref": "#/$defs/effect_ids" }
      }
    },
    "shop_offer": {
      "oneOf": [
        { "$ref": "#/$defs/visible_shop_offer" },
        { "$ref": "#/$defs/mystery_shop_offer" }
      ]
    },
    "visible_shop_offer": {
      "type": "object",
      "required": ["offer_id", "kind", "item_def_id", "display_name", "buy_price"],
      "additionalProperties": false,
      "properties": {
        "offer_id": { "type": "string", "pattern": "^(fixed|generated|buyback):[a-z0-9_:-]+$" },
        "kind": { "type": "string", "enum": ["fixed", "generated", "buyback"] },
        "item_def_id": { "type": "string" },
        "item_template_id": { "type": "string" },
        "display_name": { "type": "string", "minLength": 1 },
        "rarity": { "type": "string" },
        "slot": { "$ref": "#/$defs/shop_slot" },
        "category": { "type": "string" },
        "rolled_stats": { "$ref": "#/$defs/rolled_stats" },
        "requirements": { "$ref": "#/$defs/requirements" },
        "requirement_status": { "$ref": "#/$defs/requirement_status_list" },
        "requirements_met": { "type": "boolean" },
        "equip_preview": { "$ref": "#/$defs/equip_preview" },
        "effect_ids": { "$ref": "#/$defs/effect_ids" },
        "buy_price": { "type": "integer", "minimum": 1 },
        "summary_lines": { "$ref": "#/$defs/shop_summary_lines" },
        "comparison": { "$ref": "#/$defs/shop_item_comparison" },
        "source": { "type": "string" },
        "depth": { "type": "integer", "minimum": 1 },
        "source_depth": { "type": "integer", "minimum": 1 }
      }
    },
    "mystery_shop_offer": {
      "type": "object",
      "required": ["offer_id", "kind", "concealed", "mystery_label", "slot", "category", "buy_price", "source_depth_min", "source_depth_max"],
      "additionalProperties": false,
      "properties": {
        "offer_id": { "type": "string", "pattern": "^mystery:[a-z0-9_:-]+$" },
        "kind": { "const": "mystery" },
        "concealed": { "const": true },
        "mystery_label": { "type": "string", "minLength": 1 },
        "slot": { "$ref": "#/$defs/shop_slot" },
        "category": { "type": "string" },
        "buy_price": { "type": "integer", "minimum": 1 },
        "source": { "type": "string" },
        "source_depth_min": { "type": "integer", "minimum": 1 },
        "source_depth_max": { "type": "integer", "minimum": 1 }
      }
    },
    "shop_slot": {
      "type": "string",
      "enum": ["head", "amulet", "chest", "gloves", "belt", "boots", "ring", "ring_left", "ring_right", "main_hand", "off_hand"]
    },
    "shop_stock_item": {
      "type": "object",
      "required": ["shop_id", "refresh_key", "offer_index", "offer_id", "source_depth", "item_template_id", "rolled_payload", "buy_price", "available"],
      "additionalProperties": false,
      "properties": {
        "shop_id": { "type": "string" },
        "service": { "type": "string", "enum": ["bishop", "market"] },
        "refresh_key": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "offer_index": { "type": "integer", "minimum": 0 },
        "offer_id": { "type": "string", "pattern": "^(generated|mystery):[a-z0-9_:-]+$" },
        "source_depth": { "type": "integer", "minimum": 1 },
        "item_template_id": { "type": "string" },
        "rolled_payload": { "type": "object" },
        "buy_price": { "type": "integer", "minimum": 1 },
        "available": { "type": "boolean" }
      }
    },
    "shop_summary_lines": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "shop_item_comparison_delta": {
      "type": "object",
      "required": ["stat", "offered", "equipped", "delta"],
      "additionalProperties": false,
      "properties": {
        "stat": { "type": "string" },
        "offered": { "type": "integer" },
        "equipped": { "type": "integer" },
        "delta": { "type": "integer" }
      }
    },
    "shop_item_comparison": {
      "type": "object",
      "required": ["slot", "deltas"],
      "additionalProperties": false,
      "properties": {
        "slot": { "$ref": "#/$defs/shop_slot" },
        "equipped_item_instance_id": { "$ref": "#/$defs/decimal_id" },
        "deltas": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/shop_item_comparison_delta" }
        }
      }
    },
    "shop_sell_appraisal": {
      "type": "object",
      "required": ["item_instance_id", "item_def_id", "display_name", "sell_price"],
      "additionalProperties": false,
      "properties": {
        "item_instance_id": { "$ref": "#/$defs/decimal_id" },
        "item_def_id": { "type": "string" },
        "item_template_id": { "type": "string" },
        "display_name": { "type": "string", "minLength": 1 },
        "rarity": { "type": "string" },
        "slot": { "$ref": "#/$defs/shop_slot" },
        "category": { "type": "string" },
        "rolled_stats": { "$ref": "#/$defs/rolled_stats" },
        "requirements": { "$ref": "#/$defs/requirements" },
        "requirement_status": { "$ref": "#/$defs/requirement_status_list" },
        "requirements_met": { "type": "boolean" },
        "equip_preview": { "$ref": "#/$defs/equip_preview" },
        "effect_ids": { "$ref": "#/$defs/effect_ids" },
        "sell_price": { "type": "integer", "minimum": 1 },
        "summary_lines": { "$ref": "#/$defs/shop_summary_lines" },
        "comparison": { "$ref": "#/$defs/shop_item_comparison" }
      }
    },
    "rolled_stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "damage_min": { "type": "integer", "minimum": 0 },
        "damage_max": { "type": "integer", "minimum": 0 },
        "str": { "type": "integer", "minimum": 0 },
        "dex": { "type": "integer", "minimum": 0 },
        "vit": { "type": "integer", "minimum": 0 },
        "magic": { "type": "integer", "minimum": 0 },
        "all_skills": { "type": "integer", "minimum": 0 },
        "max_hp": { "type": "integer", "minimum": 0 },
        "armor": { "type": "integer", "minimum": 0 },
        "block_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "attack_speed_percent": { "type": "integer", "minimum": -75, "maximum": 100 },
        "health_regen_per_10_seconds": { "type": "integer", "minimum": 0 },
        "mana_regen_per_10_seconds": { "type": "integer", "minimum": 0 },
        "hotbar_slots": { "type": "integer", "minimum": 0, "maximum": 10 },
        "inventory_rows": { "type": "integer", "minimum": 0, "maximum": 20 }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": { "type": "integer", "minimum": 1 },
        "str": { "type": "integer", "minimum": 1 },
        "dex": { "type": "integer", "minimum": 1 },
        "vit": { "type": "integer", "minimum": 1 },
        "magic": { "type": "integer", "minimum": 1 }
      }
    },
    "requirement_status": {
      "type": "object",
      "required": ["stat", "required", "current", "met"],
      "additionalProperties": false,
      "properties": {
        "stat": { "type": "string", "enum": ["level", "str", "dex", "vit", "magic"] },
        "required": { "type": "integer", "minimum": 1 },
        "current": { "type": "integer", "minimum": 0 },
        "met": { "type": "boolean" }
      }
    },
    "requirement_status_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement_status" }
    },
    "equip_preview_delta": {
      "type": "object",
      "required": ["stat", "current", "preview", "delta"],
      "additionalProperties": false,
      "properties": {
        "stat": { "type": "string" },
        "current": { "type": "number" },
        "preview": { "type": "number" },
        "delta": { "type": "number" }
      }
    },
    "equip_preview": {
      "type": "object",
      "required": ["slot", "requirements_met", "deltas"],
      "additionalProperties": false,
      "properties": {
        "slot": { "$ref": "#/$defs/shop_slot" },
        "requirements_met": { "type": "boolean" },
        "deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/equip_preview_delta" }
        }
      }
    },
    "effect_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "event": {
      "type": "object",
      "required": ["event_type"],
      "properties": {
        "event_type": { "type": "string" },
        "entity_id": { "$ref": "#/$defs/decimal_id" },
        "source_entity_id": { "$ref": "#/$defs/decimal_id" },
        "target_entity_id": { "$ref": "#/$defs/decimal_id" },
        "correlation_id": { "$ref": "#/$defs/prefixed_id" },
        "damage": { "type": "integer", "minimum": 0 },
        "outcome": { "type": "string", "enum": ["hit", "crit", "miss", "block", "kill"] },
        "raw_damage": { "type": "integer", "minimum": 0 },
        "mitigated_damage": { "type": "integer" },
        "blocked": { "type": "boolean" },
        "critical": { "type": "boolean" },
        "heal": { "type": "integer", "minimum": 0 },
        "mana": { "type": "integer", "minimum": 0 },
        "item_instance_id": { "$ref": "#/$defs/decimal_id" },
        "level": { "type": "integer" },
        "from_level": { "type": "integer" },
        "to_level": { "type": "integer" },
        "amount": { "type": "integer", "minimum": 0 },
        "total_experience": { "type": "integer", "minimum": 0 },
        "total_gold": { "type": "integer", "minimum": 0 },
        "stat": { "type": "string", "enum": ["str", "dex", "vit", "magic"] },
        "unspent_stat_points": { "type": "integer", "minimum": 0 },
        "skill_id": { "type": "string", "minLength": 1 },
        "rank": { "type": "integer", "minimum": 0 },
        "max_rank": { "type": "integer", "minimum": 1 },
        "unspent_skill_points": { "type": "integer", "minimum": 0 },
        "remaining_ticks": { "type": "integer", "minimum": 0 },
        "total_ticks": { "type": "integer", "minimum": 0 },
        "projectile_def_id": { "type": "string", "minLength": 1 },
        "position": { "$ref": "#/$defs/vec2" },
        "direction": { "$ref": "#/$defs/vec2" },
        "range": { "type": "number", "exclusiveMinimum": 0 },
        "angle_degrees": { "type": "number", "exclusiveMinimum": 0, "maximum": 360 },
        "reason": { "type": "string" },
        "shop_id": { "type": "string" },
        "offers": {
          "type": "array",
          "items": { "$ref": "#/$defs/shop_offer" }
        },
        "sell_appraisals": {
          "type": "array",
          "items": { "$ref": "#/$defs/shop_sell_appraisal" }
        },
        "offer_id": { "type": "string", "pattern": "^(fixed|generated|buyback|mystery):[a-z0-9_:-]+$" },
        "item": { "$ref": "#/$defs/item" },
        "price": { "type": "integer", "minimum": 0 },
        "affordable": { "type": "boolean" },
        "refresh_key": { "type": "string", "minLength": 1 },
        "stash_id": { "type": "string" },
        "stash_item_id": { "$ref": "#/$defs/decimal_id" },
        "stash_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/stash_item" }
        },
        "stash_gold": { "type": "integer", "minimum": 0 },
        "stash_capacity": { "type": "integer", "minimum": 0, "maximum": 200 },
        "corpse_character_id": { "$ref": "#/$defs/prefixed_id" },
        "corpse_name": { "type": "string" },
        "corpse_items": { "type": "array", "items": { "$ref": "#/$defs/item" } },
        "inventory": { "type": "array", "items": { "$ref": "#/$defs/item" } },
        "equipped": { "$ref": "#/$defs/equipped" },
        "hotbar": { "type": "array", "items": { "$ref": "#/$defs/hotbar_slot" } },
        "gold": { "type": "integer", "minimum": 0 },
        "inventory_rows": { "type": "integer", "minimum": 0 },
        "inventory_capacity": { "type": "integer", "minimum": 0 },
        "hotbar_capacity": { "type": "integer", "minimum": 0 },
        "character_class": { "type": "string" },
        "character_level": { "type": "integer", "minimum": 1 },
        "character_xp": { "type": "integer", "minimum": 0 },
        "pattern_id": { "type": "string" },
        "phase_index": { "type": "integer", "minimum": 0 },
        "phase_kind": { "type": "string", "enum": ["telegraph", "active", "recovery", "cooldown"] },
        "duration_ticks": { "type": "integer", "minimum": 0 },
        "telegraph": { "$ref": "#/$defs/boss_telegraph" },
        "hit_shape": { "$ref": "#/$defs/boss_hit_shape" },
        "state": { "type": "string", "enum": ["closed", "open", "ready", "locked", "disabled"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "event_type": { "enum": ["monster_damaged", "player_damaged", "player_killed"] } },
            "required": ["event_type"]
          },
          "then": { "required": ["source_entity_id", "target_entity_id", "damage"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "monster_killed" } },
            "required": ["event_type"]
          },
          "then": { "required": ["source_entity_id", "target_entity_id"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "boss_killed" } },
            "required": ["event_type"]
          },
          "then": { "required": ["source_entity_id", "target_entity_id", "boss_template_id"] }
        },
        {
          "if": {
            "properties": { "event_type": { "enum": ["item_picked_up", "loot_picked_up"] } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "item_instance_id"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "gold_picked_up" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "amount", "total_gold"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "player_healed" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "heal"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "item_used" } },
            "required": ["event_type"]
          },
          "then": {
            "required": ["item_instance_id"],
            "anyOf": [
              { "required": ["heal"] },
              { "required": ["mana"] }
            ]
          }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "player_mana_restored" } },
            "required": ["event_type"]
          },
          "then": { "required": ["mana", "item_instance_id"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "interactable_activated" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "item_dropped" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "item_instance_id"] }
        },
        {
          "if": {
            "properties": { "event_type": { "enum": ["monster_aggro", "monster_leashed"] } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "level_changed" } },
            "required": ["event_type"]
          },
          "then": { "required": ["from_level", "to_level"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "teleporter_discovered" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "level"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "experience_gained" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "amount", "total_experience"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "character_leveled" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "from_level", "to_level", "unspent_stat_points"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "stat_allocated" } },
            "required": ["event_type"]
          },
          "then": { "required": ["stat", "amount", "unspent_stat_points"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "skill_point_gained" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "amount", "unspent_skill_points"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "skill_rank_updated" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "skill_id", "rank", "unspent_skill_points"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "skill_cast" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "skill_id", "rank", "mana"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "skill_cooldown_started" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "skill_id", "remaining_ticks", "total_ticks"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "skill_cooldown_rejected" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "skill_id", "reason", "remaining_ticks"] }
        },
        {
          "if": {
            "properties": { "event_type": { "enum": ["boss_phase_started", "boss_phase_ended"] } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "pattern_id", "phase_index", "phase_kind"] }
        },
        {
          "if": {
            "properties": { "event_type": { "enum": ["descend_blocked", "teleport_blocked"] } },
            "required": ["event_type"]
          },
          "then": { "required": ["reason"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "interactable_state_changed" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "state"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "shop_opened" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "shop_id", "offers"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "shop_purchase" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "shop_id", "offer_id", "item_instance_id", "price", "total_gold", "offers", "sell_appraisals"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "shop_sale" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "shop_id", "item_instance_id", "price", "total_gold", "offers", "sell_appraisals"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "shop_reroll" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "shop_id", "price", "total_gold", "refresh_key", "offers"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "bishop_service_opened" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "service", "heal", "mana", "price", "affordable", "total_gold"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "market_service_opened" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "service"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "bishop_respec" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "service", "heal", "mana", "price", "total_gold", "unspent_stat_points", "unspent_skill_points"] }
        },
        {
          "if": {
            "properties": { "event_type": { "enum": ["bishop_debug_level_gained", "bishop_debug_skill_point_gained", "bishop_debug_stat_point_gained"] } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "service", "heal", "mana", "from_level", "to_level", "amount", "total_experience", "unspent_stat_points", "unspent_skill_points"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "stash_opened" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "stash_id", "stash_items", "stash_gold", "stash_capacity"] }
        },
        {
          "if": {
            "properties": { "event_type": { "enum": ["stash_item_deposited", "stash_item_withdrawn"] } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "stash_id", "item_instance_id", "stash_item_id"] }
        },
        {
          "if": {
            "properties": { "event_type": { "enum": ["stash_gold_deposited", "stash_gold_withdrawn"] } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "stash_id", "amount", "total_gold", "stash_gold"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "corpse_opened" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "corpse_character_id", "corpse_name", "corpse_items", "inventory", "equipped", "hotbar", "gold"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "corpse_item_recovered" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "corpse_character_id", "corpse_name", "item_instance_id", "stash_item_id", "corpse_items", "inventory", "equipped", "hotbar", "gold"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "unique_chest_opened" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "service", "stash_items", "inventory", "equipped", "hotbar", "gold"] }
        },
        {
          "if": {
            "properties": { "event_type": { "const": "unique_chest_item_taken" } },
            "required": ["event_type"]
          },
          "then": { "required": ["entity_id", "service", "item_instance_id", "stash_item_id", "stash_items", "inventory", "equipped", "hotbar", "gold"] }
        }
      ]
    },
    "boss_phase": {
      "type": "object",
      "required": ["pattern_id", "phase_index", "phase_kind", "started_tick", "remaining_ticks"],
      "additionalProperties": false,
      "properties": {
        "pattern_id": { "type": "string" },
        "phase_index": { "type": "integer", "minimum": 0 },
        "phase_kind": { "type": "string", "enum": ["telegraph", "active", "recovery", "cooldown"] },
        "started_tick": { "type": "integer", "minimum": 0 },
        "remaining_ticks": { "type": "integer", "minimum": 0 },
        "telegraph": { "$ref": "#/$defs/boss_telegraph" },
        "hit_shape": { "$ref": "#/$defs/boss_hit_shape" }
      }
    },
    "boss_telegraph": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["body_color_charge", "circle", "line", "cone", "rectangle"] },
        "from_color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "to_color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "radius": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "boss_hit_shape": {
      "type": "object",
      "required": ["shape"],
      "additionalProperties": false,
      "properties": {
        "shape": { "type": "string", "enum": ["melee_contact", "circle", "line", "cone", "rectangle"] },
        "radius": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "base_stats": {
      "type": "object",
      "required": ["str", "dex", "vit", "magic"],
      "additionalProperties": false,
      "properties": {
        "str": { "type": "integer", "minimum": 0 },
        "dex": { "type": "integer", "minimum": 0 },
        "vit": { "type": "integer", "minimum": 0 },
        "magic": { "type": "integer", "minimum": 0 }
      }
    },
    "derived_stats": {
      "type": "object",
      "required": ["damage_min", "damage_max", "armor", "attack_speed", "attack_interval_ticks", "hit_chance", "crit_chance", "crit_damage", "movement_speed", "max_hp", "max_mana", "health_regen_per_second", "mana_regen_per_second"],
      "additionalProperties": false,
      "properties": {
        "damage_min": { "type": "number", "minimum": 0 },
        "damage_max": { "type": "number", "minimum": 0 },
        "armor": { "type": "number", "minimum": 0 },
        "attack_speed": { "type": "number", "minimum": 0 },
        "attack_interval_ticks": { "type": "integer", "minimum": 1 },
        "hit_chance": { "type": "number", "minimum": 0, "maximum": 1 },
        "crit_chance": { "type": "number", "minimum": 0, "maximum": 1 },
        "crit_damage": { "type": "number", "minimum": 0 },
        "movement_speed": { "type": "number", "minimum": 0 },
        "max_hp": { "type": "number", "minimum": 1 },
        "max_mana": { "type": "number", "minimum": 0 },
        "health_regen_per_second": { "type": "number", "minimum": 0 },
        "mana_regen_per_second": { "type": "number", "minimum": 0 }
      }
    },
    "stat_breakdown_source": {
      "type": "object",
      "required": ["label", "value", "kind"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "kind": { "type": "string", "enum": ["character_formula", "equipment_base", "equipment_roll", "cap", "clamp"] },
        "item_instance_id": { "$ref": "#/$defs/decimal_id" }
      }
    },
    "stat_breakdown": {
      "type": "object",
      "required": ["key", "value", "sources"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "enum": ["damage_min", "damage_max", "armor", "attack_speed", "attack_interval_ticks", "hit_chance", "crit_chance", "crit_damage", "max_hp", "max_mana", "health_regen_per_second", "mana_regen_per_second", "block_percent"] },
        "value": { "type": "number" },
        "uncapped_value": { "type": "number" },
        "cap": { "type": ["number", "null"] },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/stat_breakdown_source" }
        }
      }
    },
    "character_progression": {
      "type": "object",
      "required": ["level", "experience", "experience_to_next_level", "level_cap", "unspent_stat_points", "gold", "deepest_dungeon_depth", "base_stats", "derived_stats"],
      "additionalProperties": false,
      "properties": {
        "level": { "type": "integer", "minimum": 1 },
        "experience": { "type": "integer", "minimum": 0 },
        "experience_to_next_level": { "type": ["integer", "null"], "minimum": 0 },
        "level_cap": { "type": "integer", "minimum": 1 },
        "unspent_stat_points": { "type": "integer", "minimum": 0 },
        "gold": { "type": "integer", "minimum": 0 },
        "deepest_dungeon_depth": { "type": "integer", "minimum": 0 },
        "base_stats": { "$ref": "#/$defs/base_stats" },
        "derived_stats": { "$ref": "#/$defs/derived_stats" },
        "stat_breakdowns": {
          "type": "array",
          "items": { "$ref": "#/$defs/stat_breakdown" }
        }
      }
    },
    "skill_progression_skill": {
      "type": "object",
      "required": ["skill_id", "rank", "max_rank", "can_spend"],
      "additionalProperties": false,
      "properties": {
        "skill_id": { "type": "string", "minLength": 1 },
        "rank": { "type": "integer", "minimum": 0 },
        "max_rank": { "type": "integer", "minimum": 1 },
        "can_spend": { "type": "boolean" }
      }
    },
    "skill_progression": {
      "type": "object",
      "required": ["unspent_skill_points", "skills"],
      "additionalProperties": false,
      "properties": {
        "unspent_skill_points": { "type": "integer", "minimum": 0 },
        "skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/skill_progression_skill" }
        }
      }
    },
    "skill_cooldown": {
      "type": "object",
      "required": ["skill_id", "remaining_ticks", "total_ticks"],
      "additionalProperties": false,
      "properties": {
        "skill_id": { "type": "string", "minLength": 1 },
        "remaining_ticks": { "type": "integer", "minimum": 0 },
        "total_ticks": { "type": "integer", "minimum": 0 }
      }
    },
    "skill_bindings": {
      "type": "object",
      "required": ["function_keys", "right_click_skill_id"],
      "additionalProperties": false,
      "properties": {
        "function_keys": {
          "type": "array",
          "minItems": 16,
          "maxItems": 16,
          "items": { "type": "string" }
        },
        "right_click_skill_id": { "type": "string" }
      }
    },
    "change": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "entity"],
          "properties": { "op": { "const": "entity_spawn" }, "entity": { "$ref": "#/$defs/entity" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "entity"],
          "properties": { "op": { "const": "entity_update" }, "entity": { "$ref": "#/$defs/entity" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "entity_id"],
          "properties": { "op": { "const": "entity_remove" }, "entity_id": { "$ref": "#/$defs/decimal_id" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "walls"],
          "properties": {
            "op": { "const": "wall_layout_update" },
            "walls": { "type": "array", "items": { "$ref": "#/$defs/wall" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "item"],
          "properties": { "op": { "const": "inventory_add" }, "item": { "$ref": "#/$defs/item" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "item"],
          "properties": { "op": { "const": "inventory_update" }, "item": { "$ref": "#/$defs/item" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "item_instance_id"],
          "properties": {
            "op": { "const": "inventory_remove" },
            "item_instance_id": { "$ref": "#/$defs/decimal_id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "slot", "item_instance_id"],
          "properties": {
            "op": { "const": "equipped_update" },
            "slot": { "type": "string", "enum": ["head", "amulet", "chest", "gloves", "belt", "boots", "ring_left", "ring_right", "main_hand", "off_hand"] },
            "item_instance_id": { "oneOf": [ { "$ref": "#/$defs/decimal_id" }, { "type": "null" } ] },
            "hotbar_capacity": { "type": "integer", "minimum": 2, "maximum": 10 },
            "inventory_rows": { "type": "integer", "minimum": 0, "maximum": 20 },
            "inventory_capacity": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "active_weapon_set", "weapon_sets"],
          "properties": {
            "op": { "const": "weapon_set_update" },
            "active_weapon_set": { "type": "integer", "minimum": 0, "maximum": 1 },
            "weapon_sets": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "$ref": "#/$defs/weapon_set" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "slot_index", "item_instance_id"],
          "properties": {
            "op": { "const": "hotbar_update" },
            "slot_index": { "type": "integer", "minimum": 0, "maximum": 9 },
            "item_instance_id": { "oneOf": [ { "$ref": "#/$defs/decimal_id" }, { "type": "null" } ] },
            "item": { "$ref": "#/$defs/item" },
            "inventory_rows": { "type": "integer", "minimum": 0, "maximum": 20 },
            "inventory_capacity": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "gold"],
          "properties": {
            "op": { "const": "gold_update" },
            "gold": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "item"],
          "properties": {
            "op": { "const": "stash_item_add" },
            "item": { "$ref": "#/$defs/stash_item" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "stash_item_id"],
          "properties": {
            "op": { "const": "stash_item_remove" },
            "stash_item_id": { "$ref": "#/$defs/decimal_id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "stash_gold"],
          "properties": {
            "op": { "const": "stash_gold_update" },
            "stash_gold": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "level", "discovered"],
          "properties": {
            "op": { "const": "teleporter_discovery_update" },
            "level": { "type": "integer", "maximum": 0 },
            "discovered": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "character_progression"],
          "properties": {
            "op": { "const": "character_progression_update" },
            "character_progression": { "$ref": "#/$defs/character_progression" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "skill_progression"],
          "properties": {
            "op": { "const": "skill_progression_update" },
            "skill_progression": { "$ref": "#/$defs/skill_progression" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "skill_cooldowns"],
          "properties": {
            "op": { "const": "skill_cooldown_update" },
            "skill_cooldowns": { "type": "array", "items": { "$ref": "#/$defs/skill_cooldown" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "skill_bindings"],
          "properties": {
            "op": { "const": "skill_bindings_update" },
            "skill_bindings": { "$ref": "#/$defs/skill_bindings" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "shop_id", "refresh_key", "stock"],
          "properties": {
            "op": { "const": "shop_stock_replace" },
            "shop_id": { "type": "string" },
            "refresh_key": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "stock": { "type": "array", "items": { "$ref": "#/$defs/shop_stock_item" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "shop_id", "offer_id", "available"],
          "properties": {
            "op": { "const": "shop_stock_availability_update" },
            "shop_id": { "type": "string" },
            "offer_id": { "type": "string", "pattern": "^generated:[a-z0-9_:-]+$" },
            "available": { "type": "boolean" }
          }
        }
      ]
    }
  }
}
