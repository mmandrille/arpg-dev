{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/boss_templates.v0.schema.json",
  "title": "Boss templates (v0)",
  "type": "object",
  "required": ["version", "bosses"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "bosses": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "name",
          "base_monster_def_id",
          "pattern_deck",
          "hp_multiplier",
          "damage_multiplier",
          "loot_table",
          "visual"
        ],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "base_monster_def_id": { "type": "string", "minLength": 1 },
          "pattern_deck": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "hp_multiplier": { "type": "number", "exclusiveMinimum": 0 },
          "damage_multiplier": { "type": "number", "exclusiveMinimum": 0 },
          "loot_table": { "type": "string", "minLength": 1 },
          "visual": {
            "type": "object",
            "required": ["model", "color", "scale"],
            "additionalProperties": false,
            "properties": {
              "model": { "type": "string", "minLength": 1 },
              "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
              "scale": { "type": "number", "exclusiveMinimum": 0 }
            }
          }
        }
      }
    }
  }
}
