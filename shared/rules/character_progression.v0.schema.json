{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/character_progression.v0.schema.json",
  "title": "Character progression rules (v0)",
  "description": "Declarative character stats, XP thresholds, level-up points, and bounded derived-stat formulas.",
  "type": "object",
  "required": ["version", "base_stats", "points_per_level", "level_cap", "experience_curve", "derived_stats"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "base_stats": { "$ref": "#/$defs/base_stats" },
    "points_per_level": { "type": "integer", "minimum": 1 },
    "level_cap": { "type": "integer", "minimum": 2 },
    "experience_curve": {
      "type": "object",
      "required": ["type", "levels"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "table" },
        "levels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["level", "next_level_total_xp"],
            "additionalProperties": false,
            "properties": {
              "level": { "type": "integer", "minimum": 1 },
              "next_level_total_xp": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "derived_stats": {
      "type": "object",
      "required": [
        "damage_min",
        "damage_max",
        "armor",
        "attack_speed",
        "hit_chance",
        "crit_chance",
        "crit_damage",
        "movement_speed",
        "max_hp",
        "max_mana"
      ],
      "additionalProperties": false,
      "properties": {
        "damage_min": { "$ref": "#/$defs/linear_formula" },
        "damage_max": { "$ref": "#/$defs/linear_formula" },
        "armor": { "$ref": "#/$defs/linear_formula" },
        "attack_speed": { "$ref": "#/$defs/linear_formula" },
        "hit_chance": { "$ref": "#/$defs/linear_formula" },
        "crit_chance": { "$ref": "#/$defs/linear_formula" },
        "crit_damage": { "$ref": "#/$defs/linear_formula" },
        "movement_speed": { "$ref": "#/$defs/linear_formula" },
        "max_hp": { "$ref": "#/$defs/linear_formula" },
        "max_mana": { "$ref": "#/$defs/linear_formula" }
      }
    }
  },
  "$defs": {
    "base_stats": {
      "type": "object",
      "required": ["str", "dex", "vit", "magic"],
      "additionalProperties": false,
      "properties": {
        "str": { "type": "integer", "minimum": 1 },
        "dex": { "type": "integer", "minimum": 1 },
        "vit": { "type": "integer", "minimum": 1 },
        "magic": { "type": "integer", "minimum": 1 }
      }
    },
    "linear_formula": {
      "type": "object",
      "required": ["type", "base"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "linear" },
        "base": { "type": "number" },
        "per_str": { "type": "number" },
        "per_dex": { "type": "number" },
        "per_vit": { "type": "number" },
        "per_magic": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    }
  }
}
