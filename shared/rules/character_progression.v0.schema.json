{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/character_progression.v0.schema.json",
  "title": "Character progression rules (v0)",
  "description": "Declarative character stats, XP thresholds, level-up stat/skill points, and bounded derived-stat formulas.",
  "type": "object",
  "required": ["version", "base_stats", "classes", "points_per_level", "skill_points", "level_cap", "experience_curve", "derived_stats"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "base_stats": { "$ref": "#/$defs/base_stats" },
    "classes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/character_class" }
    },
    "points_per_level": { "type": "integer", "minimum": 1 },
    "skill_points": {
      "type": "object",
      "required": ["points_per_grant", "grant_every_levels", "first_grant_level"],
      "additionalProperties": false,
      "properties": {
        "points_per_grant": { "type": "integer", "minimum": 1 },
        "grant_every_levels": { "type": "integer", "minimum": 1 },
        "first_grant_level": { "type": "integer", "minimum": 1 }
      }
    },
    "level_cap": { "type": "integer", "minimum": 2 },
    "experience_curve": {
      "type": "object",
      "required": ["type", "levels"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "table" },
        "levels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["level", "next_level_total_xp"],
            "additionalProperties": false,
            "properties": {
              "level": { "type": "integer", "minimum": 1 },
              "next_level_total_xp": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "derived_stats": {
      "type": "object",
      "required": [
        "damage_min",
        "damage_max",
        "armor",
        "attack_speed",
        "hit_chance",
        "crit_chance",
        "crit_damage",
        "movement_speed",
        "max_hp",
        "max_mana",
        "health_regen_per_second",
        "mana_regen_per_second"
      ],
      "additionalProperties": false,
      "properties": {
        "damage_min": { "$ref": "#/$defs/derived_formula" },
        "damage_max": { "$ref": "#/$defs/derived_formula" },
        "armor": { "$ref": "#/$defs/derived_formula" },
        "attack_speed": { "$ref": "#/$defs/derived_formula" },
        "hit_chance": { "$ref": "#/$defs/derived_formula" },
        "crit_chance": { "$ref": "#/$defs/derived_formula" },
        "crit_damage": { "$ref": "#/$defs/derived_formula" },
        "movement_speed": { "$ref": "#/$defs/derived_formula" },
        "max_hp": { "$ref": "#/$defs/derived_formula" },
        "max_mana": { "$ref": "#/$defs/derived_formula" },
        "health_regen_per_second": { "$ref": "#/$defs/derived_formula" },
        "mana_regen_per_second": { "$ref": "#/$defs/derived_formula" }
      }
    }
  },
  "$defs": {
    "base_stats": {
      "type": "object",
      "required": ["str", "dex", "vit", "magic"],
      "additionalProperties": false,
      "properties": {
        "str": { "type": "integer", "minimum": 1 },
        "dex": { "type": "integer", "minimum": 1 },
        "vit": { "type": "integer", "minimum": 1 },
        "magic": { "type": "integer", "minimum": 1 }
      }
    },
    "character_class": {
      "type": "object",
      "required": ["name", "base_stats"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "base_stats": { "$ref": "#/$defs/base_stats" }
      }
    },
    "derived_formula": {
      "oneOf": [
        { "$ref": "#/$defs/linear_formula" },
        { "$ref": "#/$defs/logarithmic_formula" }
      ]
    },
    "linear_formula": {
      "type": "object",
      "required": ["type", "base"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "linear" },
        "base": { "type": "number" },
        "per_str": { "type": "number" },
        "per_dex": { "type": "number" },
        "per_vit": { "type": "number" },
        "per_magic": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "logarithmic_formula": {
      "type": "object",
      "required": ["type", "base", "stat", "scale", "denominator"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "logarithmic" },
        "base": { "type": "number" },
        "stat": { "type": "string", "enum": ["str", "dex", "vit", "magic"] },
        "scale": { "type": "number" },
        "offset": { "type": "number" },
        "denominator": { "type": "number", "exclusiveMinimum": 0 },
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    }
  }
}
