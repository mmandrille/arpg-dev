{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/dungeon_generation.v0.schema.json",
  "title": "Dungeon generation rules (v0)",
  "type": "object",
  "required": [
    "version",
    "floor_size",
    "wall_thickness",
    "player_spawn",
    "stair_placement",
    "teleporter_placement",
    "monster_placement",
    "chest_placement",
    "elite_objective",
    "obstacle_generation",
    "boss_floor",
    "monster_rarity_note",
    "monster_depth_scaling",
    "monster_rarities",
    "loot_band_note",
    "loot_bands",
    "level_names",
    "default_level_name_template"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "floor_size": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "wall_thickness": { "type": "number", "exclusiveMinimum": 0 },
    "player_spawn": { "$ref": "#/$defs/position" },
    "stair_placement": {
      "type": "object",
      "required": ["min_separation", "margin_from_wall", "max_attempts"],
      "additionalProperties": false,
      "properties": {
        "min_separation": { "type": "number", "exclusiveMinimum": 0 },
        "margin_from_wall": { "type": "number", "minimum": 0 },
        "max_attempts": { "type": "integer", "minimum": 1 }
      }
    },
    "teleporter_placement": {
      "type": "object",
      "required": ["margin_from_wall", "min_stair_distance", "max_attempts"],
      "additionalProperties": false,
      "properties": {
        "margin_from_wall": { "type": "number", "minimum": 0 },
        "min_stair_distance": { "type": "number", "exclusiveMinimum": 0 },
        "max_attempts": { "type": "integer", "minimum": 1 }
      }
    },
    "monster_placement": {
      "type": "object",
      "required": ["count", "monster_def_id", "pack_count", "pack_size", "pack_member_radius", "pack_composition", "elite_pack_chance_percent", "margin_from_wall", "min_spawn_distance", "max_attempts"],
      "additionalProperties": false,
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "monster_def_id": { "type": "string", "minLength": 1 },
        "pack_count": { "$ref": "#/$defs/int_range" },
        "pack_size": { "$ref": "#/$defs/int_range" },
        "pack_member_radius": { "type": "number", "exclusiveMinimum": 0 },
        "pack_composition": {
          "type": "object",
          "required": ["frontline_min", "ranged_max"],
          "additionalProperties": false,
          "properties": {
            "frontline_min": { "type": "integer", "minimum": 1 },
            "ranged_max": { "type": "integer", "minimum": 0 }
          }
        },
        "elite_pack_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "elite_aura": {
          "type": "object",
          "required": ["id", "radius", "damage_bonus_percent"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "radius": { "type": "number", "exclusiveMinimum": 0 },
            "damage_bonus_percent": { "type": "integer", "minimum": 0, "maximum": 200 }
          }
        },
        "monster_pool": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/monster_pool_entry" }
        },
        "minimum_monsters": {
          "type": "array",
          "items": { "$ref": "#/$defs/minimum_monster_entry" }
        },
        "margin_from_wall": { "type": "number", "minimum": 0 },
        "min_spawn_distance": { "type": "number", "exclusiveMinimum": 0 },
        "max_attempts": { "type": "integer", "minimum": 1 }
      }
    },
    "chest_placement": {
      "type": "object",
      "required": [
        "enabled",
        "chance_weight",
        "no_chest_weight",
        "interactable_def_id",
        "loot_table",
        "monster_count_bonus",
        "min_stair_distance",
        "max_attempts"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "chance_weight": { "type": "integer", "minimum": 0 },
        "no_chest_weight": { "type": "integer", "minimum": 0 },
        "interactable_def_id": { "type": "string", "minLength": 1 },
        "loot_table": { "type": "string", "minLength": 1 },
        "monster_count_bonus": { "type": "integer", "minimum": 0 },
        "min_stair_distance": { "type": "number", "exclusiveMinimum": 0 },
        "max_attempts": { "type": "integer", "minimum": 1 }
      }
    },
    "elite_objective": {
      "type": "object",
      "required": ["enabled", "interactable_def_id", "loot_table", "min_stair_distance", "max_attempts"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "interactable_def_id": { "type": "string", "minLength": 1 },
        "loot_table": { "type": "string", "minLength": 1 },
        "min_stair_distance": { "type": "number", "exclusiveMinimum": 0 },
        "max_attempts": { "type": "integer", "minimum": 1 }
      }
    },
    "obstacle_generation": {
      "type": "object",
      "required": [
        "enabled",
        "max_attempts",
        "target_group_count",
        "wall_segment",
        "solid_block",
        "shape_weights",
        "clearance"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "target_group_count": { "$ref": "#/$defs/int_range" },
        "wall_segment": {
          "type": "object",
          "required": ["min_length", "max_length", "thickness"],
          "additionalProperties": false,
          "properties": {
            "min_length": { "type": "integer", "minimum": 1 },
            "max_length": { "type": "integer", "minimum": 1 },
            "thickness": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "solid_block": {
          "type": "object",
          "required": ["min_size", "max_size"],
          "additionalProperties": false,
          "properties": {
            "min_size": { "$ref": "#/$defs/positive_size" },
            "max_size": { "$ref": "#/$defs/positive_size" }
          }
        },
        "shape_weights": {
          "type": "object",
          "required": ["line", "l", "t", "block"],
          "additionalProperties": false,
          "properties": {
            "line": { "type": "integer", "minimum": 0 },
            "l": { "type": "integer", "minimum": 0 },
            "t": { "type": "integer", "minimum": 0 },
            "block": { "type": "integer", "minimum": 0 }
          }
        },
        "clearance": {
          "type": "object",
          "required": ["player_spawn", "stairs", "teleporter", "chest", "monster", "loot"],
          "additionalProperties": false,
          "properties": {
            "player_spawn": { "type": "number", "minimum": 0 },
            "stairs": { "type": "number", "minimum": 0 },
            "teleporter": { "type": "number", "minimum": 0 },
            "chest": { "type": "number", "minimum": 0 },
            "monster": { "type": "number", "minimum": 0 },
            "loot": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "boss_floor": {
      "type": "object",
      "required": [
        "cadence",
        "first_level",
        "floor_size",
        "monster_count",
        "chest_interactable_def_id",
        "chest_loot_table",
        "boss_template_pool",
        "boss_spawn",
        "chest_position",
        "stairs_up_position",
        "stairs_down_position",
        "teleporter_position",
        "locked_exit_reason"
      ],
      "additionalProperties": false,
      "properties": {
        "cadence": { "type": "integer", "minimum": 1 },
        "first_level": { "type": "integer", "maximum": -1 },
        "floor_size": { "$ref": "#/$defs/floor_size" },
        "monster_count": { "type": "integer", "minimum": 0 },
        "chest_interactable_def_id": { "type": "string", "minLength": 1 },
        "chest_loot_table": { "type": "string", "minLength": 1 },
        "boss_template_pool": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "boss_spawn": { "$ref": "#/$defs/position" },
        "chest_position": { "$ref": "#/$defs/position" },
        "stairs_up_position": { "$ref": "#/$defs/position" },
        "stairs_down_position": { "$ref": "#/$defs/position" },
        "teleporter_position": { "$ref": "#/$defs/position" },
        "locked_exit_reason": { "type": "string", "minLength": 1 }
      }
    },
    "loot_band_note": { "type": "string", "minLength": 1 },
    "monster_rarity_note": { "type": "string", "minLength": 1 },
    "monster_depth_scaling": {
      "type": "object",
      "required": [
        "hp_per_depth",
        "damage_per_depth",
        "armor_per_depth",
        "hit_chance_per_depth",
        "max_hit_chance",
        "crit_chance_per_depth",
        "max_crit_chance",
        "block_percent_per_depth",
        "max_block_percent",
        "attack_cooldown_multiplier_per_depth",
        "min_attack_cooldown_ticks"
      ],
      "additionalProperties": false,
      "properties": {
        "hp_per_depth": { "type": "number", "minimum": 0 },
        "damage_per_depth": { "type": "number", "minimum": 0 },
        "armor_per_depth": { "type": "number", "minimum": 0 },
        "hit_chance_per_depth": { "type": "number", "minimum": 0 },
        "max_hit_chance": { "type": "number", "minimum": 0, "maximum": 1 },
        "crit_chance_per_depth": { "type": "number", "minimum": 0 },
        "max_crit_chance": { "type": "number", "minimum": 0, "maximum": 1 },
        "block_percent_per_depth": { "type": "number", "minimum": 0 },
        "max_block_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "attack_cooldown_multiplier_per_depth": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "min_attack_cooldown_ticks": { "type": "integer", "minimum": 1 }
      }
    },
    "monster_rarities": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "id",
          "weight",
          "color",
          "hp_multiplier",
          "damage_multiplier",
          "xp_multiplier",
          "armor_multiplier",
          "armor_bonus",
          "hit_chance_bonus",
          "crit_chance_bonus",
          "block_percent_bonus",
          "attack_cooldown_multiplier",
          "loot_depth_offset",
          "visual_scale"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "weight": { "type": "integer", "minimum": 1 },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "hp_multiplier": { "type": "number", "exclusiveMinimum": 0 },
          "damage_multiplier": { "type": "number", "exclusiveMinimum": 0 },
          "xp_multiplier": { "type": "number", "exclusiveMinimum": 0 },
          "armor_multiplier": { "type": "number", "exclusiveMinimum": 0 },
          "armor_bonus": { "type": "number", "minimum": 0 },
          "hit_chance_bonus": { "type": "number", "minimum": 0 },
          "crit_chance_bonus": { "type": "number", "minimum": 0 },
          "block_percent_bonus": { "type": "number", "minimum": 0, "maximum": 100 },
          "attack_cooldown_multiplier": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
          "loot_depth_offset": { "type": "integer", "minimum": 0 },
          "visual_scale": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "loot_bands": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["min_depth", "max_depth", "monster_loot_table", "chest_loot_table"],
        "additionalProperties": false,
        "properties": {
          "min_depth": { "type": "integer", "minimum": 1 },
          "max_depth": {
            "anyOf": [
              { "type": "integer", "minimum": 1 },
              { "type": "null" }
            ]
          },
          "monster_loot_table": { "type": "string", "minLength": 1 },
          "chest_loot_table": { "type": "string", "minLength": 1 }
        }
      }
    },
    "level_names": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 },
      "propertyNames": { "pattern": "^-[0-9]+$" }
    },
    "default_level_name_template": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "position": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "floor_size": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "int_range": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    },
    "monster_pool_entry": {
      "type": "object",
      "required": ["monster_def_id", "weight"],
      "additionalProperties": false,
      "properties": {
        "monster_def_id": { "type": "string", "minLength": 1 },
        "weight": { "type": "integer", "minimum": 1 }
      }
    },
    "minimum_monster_entry": {
      "type": "object",
      "required": ["monster_def_id", "count"],
      "additionalProperties": false,
      "properties": {
        "monster_def_id": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "positive_size": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "exclusiveMinimum": 0 },
        "y": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
