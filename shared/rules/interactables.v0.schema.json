{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/interactables.v0.schema.json",
  "title": "Interactable definitions (v0)",
  "type": "object",
  "required": ["version", "interactables"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "interactables": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name", "initial_state"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "initial_state": { "type": "string", "enum": ["closed", "ready", "locked", "disabled"] },
          "transition": { "type": "string", "enum": ["ascend", "descend", "waypoint"] },
          "shop_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "stash_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "service": { "type": "string", "enum": ["bishop", "market", "mercenary", "blacksmith", "unique_test_chest", "quest_turn_in"] },
          "barrier_when_closed": {
            "type": "object",
            "required": ["size"],
            "additionalProperties": false,
            "properties": {
              "size": { "$ref": "#/$defs/size" }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "initial_state": { "const": "closed" } },
              "required": ["initial_state"]
            },
            "then": {
              "not": {
                "anyOf": [
                  { "required": ["transition"] },
                  { "required": ["shop_id"] },
                  { "required": ["stash_id"] },
                  { "required": ["service"] }
                ]
              }
            }
          },
          {
            "if": {
              "properties": { "initial_state": { "enum": ["ready", "locked", "disabled"] } },
              "required": ["initial_state"]
            },
            "then": {
              "oneOf": [
                { "required": ["transition"] },
                { "required": ["shop_id"] },
                { "required": ["stash_id"] },
                { "required": ["service"] }
              ],
              "not": { "required": ["barrier_when_closed"] }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "size": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "exclusiveMinimum": 0 },
        "y": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
