{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/items.v0.schema.json",
  "title": "Item definitions (v0)",
  "type": "object",
  "required": ["version", "items"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "items": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name", "equippable"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string", "enum": ["equipment", "currency", "quest", "consumable"] },
          "slot": { "type": "string", "enum": ["weapon"] },
          "equippable": { "type": "boolean" },
          "attack_mode": { "type": "string", "enum": ["melee", "ranged"] },
          "damage": { "$ref": "#/$defs/damage_range" },
          "reach": { "type": "number", "exclusiveMinimum": 0 },
          "projectile_speed": { "type": "number", "exclusiveMinimum": 0 }
        },
        "allOf": [
          {
            "if": {
              "properties": { "equippable": { "const": true } },
              "required": ["equippable"]
            },
            "then": { "required": ["slot"] }
          },
          {
            "if": {
              "properties": { "equippable": { "const": false } },
              "required": ["equippable"]
            },
            "then": {
              "not": {
                "anyOf": [
                  { "required": ["slot"] },
                  { "required": ["damage"] },
                  { "required": ["reach"] }
                ]
              }
            }
          },
          {
            "if": { "required": ["damage"] },
            "then": {
              "properties": {
                "equippable": { "const": true },
                "slot": { "const": "weapon" }
              },
              "required": ["equippable", "slot"]
            }
          },
          {
            "if": { "required": ["reach"] },
            "then": {
              "properties": {
                "equippable": { "const": true },
                "slot": { "const": "weapon" }
              },
              "required": ["equippable", "slot"]
            }
          },
          {
            "if": {
              "properties": { "attack_mode": { "const": "ranged" } },
              "required": ["attack_mode"]
            },
            "then": {
              "properties": {
                "equippable": { "const": true },
                "slot": { "const": "weapon" }
              },
              "required": ["equippable", "slot", "damage", "reach", "projectile_speed"]
            }
          },
          {
            "if": {
              "anyOf": [
                { "not": { "required": ["attack_mode"] } },
                {
                  "properties": { "attack_mode": { "const": "melee" } },
                  "required": ["attack_mode"]
                }
              ]
            },
            "then": { "not": { "required": ["projectile_speed"] } }
          }
        ]
      }
    }
  },
  "$defs": {
    "damage_range": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
