{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/items.v0.schema.json",
  "title": "Item definitions (v0)",
  "type": "object",
  "required": ["version", "items"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "items": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name", "equippable"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string", "enum": ["equipment", "currency", "quest", "consumable"] },
          "slot": {
            "type": "string",
            "enum": ["head", "amulet", "chest", "gloves", "belt", "boots", "ring_left", "ring_right", "main_hand", "off_hand"]
          },
          "equippable": { "type": "boolean" },
          "class_required": { "type": "string", "enum": ["barbarian", "sorcerer", "paladin"] },
          "handedness": { "type": "string", "enum": ["one_handed", "two_handed"] },
          "occupies_hands": {
            "type": "array",
            "items": { "type": "string", "enum": ["main_hand", "off_hand"] },
            "uniqueItems": true
          },
          "attack_mode": { "type": "string", "enum": ["melee", "ranged"] },
          "damage_type": { "$ref": "#/$defs/damage_type" },
          "attack_speed": { "type": "number", "exclusiveMinimum": 0 },
          "damage": { "$ref": "#/$defs/damage_range" },
          "reach": { "type": "number", "exclusiveMinimum": 0 },
          "projectile_speed": { "type": "number", "exclusiveMinimum": 0 },
          "heal": { "$ref": "#/$defs/use_range" },
          "mana_restore": { "$ref": "#/$defs/use_range" },
          "gold": { "$ref": "#/$defs/use_range" }
        },
        "allOf": [
          {
            "if": {
              "properties": { "equippable": { "const": true } },
              "required": ["equippable"]
            },
            "then": { "required": ["slot"] }
          },
          {
            "if": {
              "properties": { "equippable": { "const": false } },
              "required": ["equippable"]
            },
            "then": {
              "not": {
                "anyOf": [
                  { "required": ["slot"] },
                  { "required": ["damage"] },
                  { "required": ["reach"] }
                ]
              }
            }
          },
          {
            "if": { "required": ["damage"] },
            "then": {
              "properties": {
                "equippable": { "const": true },
                "slot": { "enum": ["main_hand", "off_hand"] }
              },
              "required": ["equippable", "slot"]
            }
          },
          {
            "if": { "required": ["attack_speed"] },
            "then": {
              "properties": {
                "equippable": { "const": true },
                "slot": { "enum": ["main_hand", "off_hand"] }
              },
              "required": ["equippable", "slot"]
            }
          },
          {
            "if": { "required": ["reach"] },
            "then": {
              "properties": {
                "equippable": { "const": true },
                "slot": { "enum": ["main_hand", "off_hand"] }
              },
              "required": ["equippable", "slot"]
            }
          },
          {
            "if": {
              "properties": { "attack_mode": { "const": "ranged" } },
              "required": ["attack_mode"]
            },
            "then": {
              "properties": {
                "equippable": { "const": true },
                "slot": { "enum": ["main_hand", "off_hand"] }
              },
              "required": ["equippable", "slot", "damage", "reach", "projectile_speed"]
            }
          },
          {
            "if": {
              "anyOf": [
                { "not": { "required": ["attack_mode"] } },
                {
                  "properties": { "attack_mode": { "const": "melee" } },
                  "required": ["attack_mode"]
                }
              ]
            },
            "then": { "not": { "required": ["projectile_speed"] } }
          },
          {
            "if": {
              "properties": { "category": { "const": "consumable" } },
              "required": ["category"]
            },
            "then": {
              "anyOf": [
                { "required": ["heal"] },
                { "required": ["mana_restore"] }
              ]
            }
          },
          {
            "if": {
              "required": ["heal"]
            },
            "then": {
              "properties": {
                "category": { "const": "consumable" },
                "equippable": { "const": false }
              },
              "required": ["category", "equippable"]
            }
          },
          {
            "if": {
              "required": ["mana_restore"]
            },
            "then": {
              "properties": {
                "category": { "const": "consumable" },
                "equippable": { "const": false }
              },
              "required": ["category", "equippable"]
            }
          },
          {
            "if": {
              "required": ["gold"]
            },
            "then": {
              "properties": {
                "category": { "const": "currency" },
                "equippable": { "const": false }
              },
              "required": ["category", "equippable"]
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "use_range": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer", "minimum": 1 },
        "max": { "type": "integer", "minimum": 1 }
      }
    },
    "damage_range": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    },
    "damage_type": {
      "type": "string",
      "enum": ["force", "cold", "fire", "poison", "lightning"]
    }
  }
}
