{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/loot_tables.v0.schema.json",
  "title": "Loot tables (v0)",
  "description": "Weighted-entry loot tables. The server rolls a weighted entry with the seeded PRNG; a single-entry table is deterministic regardless of seed.",
  "type": "object",
  "required": ["version", "loot_tables"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "loot_tables": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "drops": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "entries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["weight"],
              "additionalProperties": false,
              "properties": {
                "item_def_id": { "type": "string" },
                "item_template_id": { "type": "string" },
                "weight": { "type": "integer", "minimum": 1 }
              },
              "oneOf": [
                { "required": ["item_def_id"] },
                { "required": ["item_template_id"] }
              ]
            }
          },
          "treasure_class_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "anyOf": [
          { "required": ["entries"] },
          { "required": ["drops"] },
          { "required": ["treasure_class_id"] },
          { "maxProperties": 0 }
        ]
      }
    }
  }
}
