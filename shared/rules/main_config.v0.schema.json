{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/main_config.v0.schema.json",
  "title": "Main gameplay config (v0)",
  "description": "Top-level gameplay tuning values that can be adjusted before lower-level rule files are regenerated or refactored to consume them directly.",
  "type": "object",
  "required": ["version", "gameplay"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 0 },
    "gameplay": {
      "type": "object",
      "required": ["base_attack_interval_ticks", "base_movement_speed", "base_drop_rate_percent", "respec_cost_gold", "bishop_respec_resource_item_def_id", "bishop_respec_resource_count", "bishop_revive_resource_item_def_id", "bishop_revive_resource_count", "item_upgrade_cost_gold", "item_upgrade_cost_growth_per_level", "item_upgrade_max_level", "item_upgrade_success_chance_percent", "item_upgrade_pity_failure_threshold", "item_upgrade_resource_item_def_id", "item_upgrade_resource_count", "resource_loot_drops", "badge_reward_rules", "mercenary_hire_cost_gold", "quest_turn_in_item_def_id", "quest_turn_in_reward_gold", "companion_assist_radius", "companion_follow_distance", "companion_follow_stop_radius"],
      "additionalProperties": false,
      "properties": {
        "base_attack_interval_ticks": { "type": "integer", "minimum": 1 },
        "base_movement_speed": { "type": "number", "exclusiveMinimum": 0 },
        "movement_acceleration_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "movement_min_speed_factor": { "type": "number", "minimum": 0, "maximum": 1 },
        "movement_direction_grace_seconds": { "type": "number", "minimum": 0 },
        "minimum_monster_aggro_radius": { "type": "number", "minimum": 0 },
        "ranged_retreat_min_melee_engagement_seconds": { "type": "number", "minimum": 0 },
        "base_drop_rate_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "respec_cost_gold": { "type": "integer", "minimum": 0 },
        "bishop_respec_resource_item_def_id": { "type": "string", "minLength": 1 },
        "bishop_respec_resource_count": { "type": "integer", "minimum": 0 },
        "bishop_revive_resource_item_def_id": { "type": "string", "minLength": 1 },
        "bishop_revive_resource_count": { "type": "integer", "minimum": 0 },
        "item_upgrade_cost_gold": { "type": "integer", "minimum": 0 },
        "item_upgrade_cost_growth_per_level": { "type": "integer", "minimum": 0 },
        "item_upgrade_max_level": { "type": "integer", "minimum": 1 },
        "item_upgrade_success_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "item_upgrade_pity_failure_threshold": { "type": "integer", "minimum": 0 },
        "item_upgrade_resource_item_def_id": { "type": "string", "minLength": 1 },
        "item_upgrade_resource_count": { "type": "integer", "minimum": 0 },
        "resource_loot_drops": {
          "type": "object",
          "required": ["monster_common_rare_chance_percent", "monster_champion_chance_percent", "monster_unique_chance_percent", "boss_kill_chance_percent", "chest_regular_chance_percent", "chest_boss_chance_percent", "pool"],
          "additionalProperties": false,
          "properties": {
            "monster_common_rare_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
            "monster_champion_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
            "monster_unique_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
            "boss_kill_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
            "chest_regular_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
            "chest_boss_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
            "pool": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["item_def_id", "weight"],
                "additionalProperties": false,
                "properties": {
                  "item_def_id": { "type": "string", "minLength": 1 },
                  "weight": { "type": "integer", "minimum": 1 }
                }
              }
            }
          }
        },
        "badge_reward_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["resource_item_def_id", "unlock_depth", "base_chance_percent", "chance_per_depth_percent"],
            "additionalProperties": false,
            "properties": {
              "resource_item_def_id": { "type": "string", "minLength": 1 },
              "unlock_depth": { "type": "integer", "minimum": 1 },
              "base_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
              "chance_per_depth_percent": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "mercenary_hire_cost_gold": { "type": "integer", "minimum": 0 },
        "quest_turn_in_item_def_id": { "type": "string", "minLength": 1 },
        "quest_turn_in_reward_gold": { "type": "integer", "minimum": 0 },
        "companion_assist_radius": { "type": "number", "exclusiveMinimum": 0 },
        "companion_follow_distance": { "type": "number", "exclusiveMinimum": 0 },
        "companion_follow_stop_radius": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "presentation_lod": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_live_monsters": { "type": "integer", "minimum": 1 },
        "distance_threshold": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "loot_labels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "crowd_cull_min_loot": { "type": "integer", "minimum": 0 },
        "max_visible_labels": { "type": "integer", "minimum": 1 },
        "combat_radius": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "client_perf": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reconciliation_backpressure_threshold": { "type": "number", "exclusiveMinimum": 0 },
        "windup_marker_max_concurrent": { "type": "integer", "minimum": 1 },
        "projectile_visible_cap": { "type": "integer", "minimum": 1 },
        "delta_ui_sync_interval_ticks": { "type": "integer", "minimum": 1 },
        "delta_minimap_sync_interval_ticks": { "type": "integer", "minimum": 1 }
      }
    },
    "client_reconnect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initial_delay_s": { "type": "number", "exclusiveMinimum": 0 },
        "max_delay_s": { "type": "number", "exclusiveMinimum": 0 },
        "backoff_exponent": { "type": "integer", "minimum": 2 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "give_up_s": { "type": "number", "exclusiveMinimum": 0 },
        "http_resume_after_ws_failures": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
