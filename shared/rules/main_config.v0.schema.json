{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/main_config.v0.schema.json",
  "title": "Main gameplay config (v0)",
  "description": "Top-level gameplay tuning values that can be adjusted before lower-level rule files are regenerated or refactored to consume them directly.",
  "type": "object",
  "required": ["version", "gameplay"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 0 },
    "gameplay": {
      "type": "object",
      "required": ["base_attack_interval_ticks", "base_movement_speed", "base_drop_rate_percent", "respec_cost_gold", "bishop_respec_resource_item_def_id", "bishop_respec_resource_count", "bishop_revive_resource_item_def_id", "bishop_revive_resource_count", "item_upgrade_cost_gold", "item_upgrade_cost_growth_per_level", "item_upgrade_max_level", "item_upgrade_success_chance_percent", "item_upgrade_pity_failure_threshold", "item_upgrade_resource_item_def_id", "item_upgrade_resource_count", "badge_reward_rules", "mercenary_hire_cost_gold", "quest_turn_in_item_def_id", "quest_turn_in_reward_gold", "companion_assist_radius", "companion_follow_distance", "companion_follow_stop_radius"],
      "additionalProperties": false,
      "properties": {
        "base_attack_interval_ticks": { "type": "integer", "minimum": 1 },
        "base_movement_speed": { "type": "number", "exclusiveMinimum": 0 },
        "movement_acceleration_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "movement_min_speed_factor": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_monster_aggro_radius": { "type": "number", "minimum": 0 },
        "base_drop_rate_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "respec_cost_gold": { "type": "integer", "minimum": 0 },
        "bishop_respec_resource_item_def_id": { "type": "string", "minLength": 1 },
        "bishop_respec_resource_count": { "type": "integer", "minimum": 0 },
        "bishop_revive_resource_item_def_id": { "type": "string", "minLength": 1 },
        "bishop_revive_resource_count": { "type": "integer", "minimum": 0 },
        "item_upgrade_cost_gold": { "type": "integer", "minimum": 0 },
        "item_upgrade_cost_growth_per_level": { "type": "integer", "minimum": 0 },
        "item_upgrade_max_level": { "type": "integer", "minimum": 1 },
        "item_upgrade_success_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "item_upgrade_pity_failure_threshold": { "type": "integer", "minimum": 0 },
        "item_upgrade_resource_item_def_id": { "type": "string", "minLength": 1 },
        "item_upgrade_resource_count": { "type": "integer", "minimum": 0 },
        "badge_reward_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["resource_item_def_id", "unlock_depth", "base_chance_percent", "chance_per_depth_percent"],
            "additionalProperties": false,
            "properties": {
              "resource_item_def_id": { "type": "string", "minLength": 1 },
              "unlock_depth": { "type": "integer", "minimum": 1 },
              "base_chance_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
              "chance_per_depth_percent": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "mercenary_hire_cost_gold": { "type": "integer", "minimum": 0 },
        "quest_turn_in_item_def_id": { "type": "string", "minLength": 1 },
        "quest_turn_in_reward_gold": { "type": "integer", "minimum": 0 },
        "companion_assist_radius": { "type": "number", "exclusiveMinimum": 0 },
        "companion_follow_distance": { "type": "number", "exclusiveMinimum": 0 },
        "companion_follow_stop_radius": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
