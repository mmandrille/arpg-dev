{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/monsters.v0.schema.json",
  "title": "Monster definitions (v0)",
  "description": "Source of truth for monster HP, optional retaliation damage, and which loot table they roll on death.",
  "type": "object",
  "required": ["version", "monsters"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "monsters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
          "required": ["name", "max_hp", "loot_table"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "max_hp": { "type": "integer", "minimum": 1 },
            "loot_table": { "type": "string" },
            "xp_reward": { "type": "integer", "minimum": 0 },
            "hit_chance": { "type": "number", "minimum": 0, "maximum": 1 },
            "crit_chance": { "type": "number", "minimum": 0, "maximum": 1 },
            "crit_damage": { "type": "number", "minimum": 1 },
            "armor": { "type": "integer", "minimum": 0 },
            "block_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
            "retaliation_damage": {
              "type": "object",
              "required": ["min", "max"],
              "additionalProperties": false,
              "properties": {
                "min": { "type": "integer", "minimum": 0 },
                "max": { "type": "integer", "minimum": 0 }
              }
            },
            "attack_damage": {
              "type": "object",
              "required": ["min", "max"],
              "additionalProperties": false,
              "properties": {
                "min": { "type": "integer", "minimum": 0 },
                "max": { "type": "integer", "minimum": 0 }
              }
            },
            "attack_cooldown_ticks": { "type": "integer", "minimum": 1 },
            "attack_mode": { "type": "string", "enum": ["melee", "ranged"] },
            "attack_range": { "type": "number", "exclusiveMinimum": 0 },
            "projectile_speed": { "type": "number", "exclusiveMinimum": 0 },
            "projectile_def_id": { "type": "string", "minLength": 1 },
            "behavior": { "type": "string", "enum": ["static", "chase"] },
            "pack_role": { "type": "string", "enum": ["frontline", "ranged", "flanker", "swarm"] },
            "aggro_radius": { "type": "number", "exclusiveMinimum": 0 },
            "assist_radius": { "type": "number", "exclusiveMinimum": 0 },
            "leash_radius": { "type": "number", "exclusiveMinimum": 0 },
            "move_speed": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
  }
}
