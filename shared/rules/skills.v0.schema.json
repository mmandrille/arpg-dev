{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/skills.v0.schema.json",
  "title": "Skill rules (v0)",
  "description": "Declarative active-skill catalog. The Go sim owns authoritative validation, cooldowns, mana spend, projectiles, buffs, healing, and damage.",
  "type": "object",
  "required": ["version", "skills"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/skill" }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": ["name", "class", "tree", "kind", "max_rank", "targeting", "requirements", "cost", "cooldown"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "name_key": { "type": "string", "minLength": 1 },
        "class": { "type": "string", "minLength": 1 },
        "damage_type": { "$ref": "#/$defs/damage_type" },
        "tree": { "$ref": "#/$defs/tree_position" },
        "kind": { "type": "string", "enum": ["projectile_attack", "cold_projectile_attack", "chain_projectile_attack", "cone_attack", "self_buff", "area_heal", "area_stat_buff"] },
        "max_rank": { "type": "integer", "minimum": 1 },
        "targeting": { "type": "string", "enum": ["direction_or_target", "self", "direction_or_target_area", "self_or_ally_area"] },
        "requirements": { "$ref": "#/$defs/requirements" },
        "cost": { "$ref": "#/$defs/cost" },
        "damage": { "$ref": "#/$defs/rank_linear_damage" },
        "projectile": { "$ref": "#/$defs/projectile" },
        "pierce": { "$ref": "#/$defs/pierce" },
        "root": { "$ref": "#/$defs/root" },
        "volley": { "$ref": "#/$defs/volley" },
        "cone": { "$ref": "#/$defs/cone" },
        "poison": { "$ref": "#/$defs/poison" },
        "dash": { "$ref": "#/$defs/dash" },
        "slow": { "$ref": "#/$defs/slow" },
        "shatter": { "$ref": "#/$defs/shatter" },
        "chain": { "$ref": "#/$defs/chain" },
        "effects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skill_effect" }
        },
        "cooldown": { "$ref": "#/$defs/cooldown" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "projectile_attack" } }, "required": ["kind"] },
          "then": {
            "required": ["damage", "projectile"],
            "properties": { "targeting": { "const": "direction_or_target" } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "cold_projectile_attack" } }, "required": ["kind"] },
          "then": {
            "required": ["damage", "projectile", "slow", "shatter"],
            "properties": { "targeting": { "const": "direction_or_target" } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "chain_projectile_attack" } }, "required": ["kind"] },
          "then": {
            "required": ["damage", "projectile", "chain"],
            "properties": { "targeting": { "const": "direction_or_target" } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "cone_attack" } }, "required": ["kind"] },
          "then": {
            "required": ["cone"],
            "properties": { "targeting": { "const": "direction_or_target" } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "self_buff" } }, "required": ["kind"] },
          "then": {
            "required": ["effects"],
            "properties": { "targeting": { "const": "self" } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "area_heal" } }, "required": ["kind"] },
          "then": {
            "required": ["effects"],
            "properties": { "targeting": { "const": "direction_or_target_area" } }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "area_stat_buff" } }, "required": ["kind"] },
          "then": {
            "required": ["effects"],
            "properties": { "targeting": { "const": "self_or_ally_area" } }
          }
        }
      ]
    },
    "tree_position": {
      "type": "object",
      "required": ["tier", "column"],
      "additionalProperties": false,
      "properties": {
        "tier": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      }
    },
    "damage_type": {
      "type": "string",
      "enum": ["force", "cold", "fire", "poison", "lightning"]
    },
    "requirements": {
      "type": "object",
      "required": ["level", "stats", "skills"],
      "additionalProperties": false,
      "properties": {
        "level": { "type": "integer", "minimum": 1 },
        "level_per_rank": { "type": "integer", "minimum": 0 },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "str": { "type": "integer", "minimum": 1 },
            "dex": { "type": "integer", "minimum": 1 },
            "vit": { "type": "integer", "minimum": 1 },
            "magic": { "type": "integer", "minimum": 1 }
          }
        },
        "stats_per_rank": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "str": { "type": "integer", "minimum": 0 },
            "dex": { "type": "integer", "minimum": 0 },
            "vit": { "type": "integer", "minimum": 0 },
            "magic": { "type": "integer", "minimum": 0 }
          }
        },
        "skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/skill_requirement" },
          "uniqueItems": true
        }
      }
    },
    "skill_requirement": {
      "type": "object",
      "required": ["skill_id", "rank"],
      "additionalProperties": false,
      "properties": {
        "skill_id": { "type": "string", "minLength": 1 },
        "rank": { "type": "integer", "minimum": 1 }
      }
    },
    "cost": {
      "type": "object",
      "required": ["mana"],
      "additionalProperties": false,
      "properties": {
        "mana": { "$ref": "#/$defs/rank_linear_integer" }
      }
    },
    "rank_linear_integer": {
      "type": "object",
      "required": ["base", "per_rank"],
      "additionalProperties": false,
      "properties": {
        "base": { "type": "integer", "minimum": 0 },
        "per_rank": { "type": "integer", "minimum": 0 }
      }
    },
    "rank_linear_damage": {
      "type": "object",
      "required": ["type", "min_base", "max_base", "min_per_rank", "max_per_rank"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "rank_linear_range" },
        "min_base": { "type": "integer", "minimum": 0 },
        "max_base": { "type": "integer", "minimum": 0 },
        "min_per_rank": { "type": "integer", "minimum": 0 },
        "max_per_rank": { "type": "integer", "minimum": 0 },
        "magic_scaling": { "$ref": "#/$defs/magic_scaling" }
      }
    },
    "magic_scaling": {
      "type": "object",
      "required": ["stat", "percent_per_point", "max_bonus_percent", "use_requirement_baseline"],
      "additionalProperties": false,
      "properties": {
        "stat": { "const": "magic" },
        "percent_per_point": { "type": "number", "exclusiveMinimum": 0 },
        "max_bonus_percent": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
        "use_requirement_baseline": { "type": "boolean" }
      }
    },
    "projectile": {
      "type": "object",
      "required": ["range", "speed", "visual"],
      "additionalProperties": false,
      "properties": {
        "range": { "type": "number", "exclusiveMinimum": 0 },
        "speed": { "type": "number", "exclusiveMinimum": 0 },
        "visual": { "type": "string", "minLength": 1 }
      }
    },
    "pierce": {
      "type": "object",
      "required": ["max_hits", "damage_percent_per_extra_hit"],
      "additionalProperties": false,
      "properties": {
        "max_hits": { "type": "integer", "minimum": 2 },
        "damage_percent_per_extra_hit": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "root": {
      "type": "object",
      "required": ["effect_id", "duration_ticks"],
      "additionalProperties": false,
      "properties": {
        "effect_id": { "type": "string", "minLength": 1 },
        "duration_ticks": { "type": "integer", "minimum": 1 }
      }
    },
    "volley": {
      "type": "object",
      "required": ["arrow_count", "spread_degrees"],
      "additionalProperties": false,
      "properties": {
        "arrow_count": { "type": "integer", "minimum": 3, "maximum": 9 },
        "spread_degrees": { "type": "number", "exclusiveMinimum": 0, "maximum": 120 }
      }
    },
    "cone": {
      "type": "object",
      "required": ["range", "angle_degrees", "push_min", "push_max", "damage_source"],
      "additionalProperties": false,
      "properties": {
        "range": { "type": "number", "exclusiveMinimum": 0 },
        "angle_degrees": { "type": "number", "exclusiveMinimum": 0, "maximum": 360 },
        "push_min": { "type": "number", "minimum": 0 },
        "push_max": { "type": "number", "minimum": 0 },
        "damage_source": { "type": "string", "enum": ["weapon"] }
      }
    },
    "poison": {
      "type": "object",
      "required": ["damage_percent_base", "damage_percent_per_rank", "duration_ticks", "magic_duration_ticks_per_point"],
      "additionalProperties": false,
      "properties": {
        "damage_percent_base": { "type": "integer", "minimum": 1 },
        "damage_percent_per_rank": { "type": "integer", "minimum": 0 },
        "duration_ticks": { "type": "integer", "minimum": 1 },
        "magic_duration_ticks_per_point": { "type": "integer", "minimum": 0 }
      }
    },
    "dash": {
      "type": "object",
      "required": ["range_base", "range_per_rank", "damage_percent_base", "damage_percent_per_magic", "max_damage_bonus_percent"],
      "additionalProperties": false,
      "properties": {
        "range_base": { "type": "number", "exclusiveMinimum": 0 },
        "range_per_rank": { "type": "number", "minimum": 0 },
        "damage_percent_base": { "type": "integer", "minimum": 1 },
        "damage_percent_per_magic": { "type": "integer", "minimum": 0 },
        "max_damage_bonus_percent": { "type": "integer", "minimum": 0 }
      }
    },
    "slow": {
      "type": "object",
      "required": ["effect_id", "percent", "duration_ticks", "max_percent"],
      "additionalProperties": false,
      "properties": {
        "effect_id": { "type": "string", "minLength": 1 },
        "percent": { "type": "integer", "minimum": 1, "maximum": 100 },
        "duration_ticks": { "type": "integer", "minimum": 1 },
        "max_percent": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "shatter": {
      "type": "object",
      "required": ["min_shards", "max_shards", "range", "speed", "visual"],
      "additionalProperties": false,
      "properties": {
        "min_shards": { "type": "integer", "minimum": 1 },
        "max_shards": { "type": "integer", "minimum": 1 },
        "range": { "type": "number", "exclusiveMinimum": 0 },
        "speed": { "type": "number", "exclusiveMinimum": 0 },
        "visual": { "type": "string", "minLength": 1 }
      }
    },
    "chain": {
      "type": "object",
      "required": ["range_multiplier", "max_jumps", "visual"],
      "additionalProperties": false,
      "properties": {
        "range_multiplier": { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1 },
        "max_jumps": { "type": "integer", "minimum": 1 },
        "visual": { "type": "string", "minLength": 1 }
      }
    },
    "skill_effect": {
      "oneOf": [
        { "$ref": "#/$defs/stat_percent_buff_effect" },
        { "$ref": "#/$defs/area_percent_heal_effect" },
        { "$ref": "#/$defs/area_stat_percent_buff_effect" }
      ]
    },
    "stat_percent_buff_effect": {
      "type": "object",
      "required": ["type", "stats", "percent_base", "percent_per_rank", "duration_ticks", "visual_scale"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "stat_percent_buff" },
        "stats": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["str", "dex", "vit", "magic"] }
        },
        "percent_base": { "type": "integer", "minimum": 0 },
        "percent_per_rank": { "type": "integer", "minimum": 0 },
        "duration_ticks": { "type": "integer", "minimum": 1 },
        "visual_scale": { "type": "boolean" }
      }
    },
    "area_percent_heal_effect": {
      "type": "object",
      "required": ["type", "target", "include_caster", "range", "radius", "percent_base", "percent_per_rank", "duration_ticks"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "area_percent_heal" },
        "target": { "const": "allies" },
        "include_caster": { "type": "boolean" },
        "range": { "type": "number", "exclusiveMinimum": 0 },
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "percent_base": { "type": "integer", "minimum": 0 },
        "percent_per_rank": { "type": "integer", "minimum": 0 },
        "duration_ticks": { "type": "integer", "minimum": 1 },
        "magic_scaling": { "$ref": "#/$defs/magic_scaling" }
      }
    },
    "area_stat_percent_buff_effect": {
      "type": "object",
      "required": ["type", "target", "include_caster", "range", "radius", "stats", "percent_base", "percent_per_rank", "duration_ticks", "effect_id"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "area_stat_percent_buff" },
        "target": { "const": "allies" },
        "include_caster": { "type": "boolean" },
        "range": { "type": "number", "exclusiveMinimum": 0 },
        "radius": { "type": "number", "exclusiveMinimum": 0 },
        "stats": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["str", "dex", "vit", "magic", "armor", "block_percent"] }
        },
        "percent_base": { "type": "integer", "minimum": 0 },
        "percent_per_rank": { "type": "integer", "minimum": 0 },
        "duration_ticks": { "type": "integer", "minimum": 1 },
        "effect_id": { "type": "string", "minLength": 1 },
        "magic_scaling": { "$ref": "#/$defs/magic_scaling" }
      }
    },
    "cooldown": {
      "type": "object",
      "required": ["type", "multiplier"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "attack_interval_multiplier" },
        "multiplier": { "type": "number", "exclusiveMinimum": 0 },
        "flat_ticks": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
