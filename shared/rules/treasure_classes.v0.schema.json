{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/treasure_classes.v0.schema.json",
  "title": "Treasure classes (v0)",
  "description": "Ordered drop attempts for server-authoritative loot sources.",
  "type": "object",
  "required": ["version", "classes"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 0 },
    "classes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["attempts"],
        "additionalProperties": false,
        "properties": {
          "attempts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["attempt_id", "success_weight", "no_drop_weight", "entries"],
              "additionalProperties": false,
              "properties": {
                "attempt_id": { "type": "string", "minLength": 1 },
                "success_weight": { "type": "integer", "minimum": 0 },
                "no_drop_weight": { "type": "integer", "minimum": 0 },
                "entries": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["weight"],
                    "additionalProperties": false,
                    "properties": {
                      "item_def_id": { "type": "string", "minLength": 1 },
                      "item_template_id": { "type": "string", "minLength": 1 },
                      "unique_item_id": { "type": "string", "minLength": 1 },
                      "set_item_id": { "type": "string", "minLength": 1 },
                      "weight": { "type": "integer", "minimum": 1 }
                    },
                    "oneOf": [
                      { "required": ["item_def_id"] },
                      { "required": ["item_template_id"] },
                      { "required": ["unique_item_id"] },
                      { "required": ["set_item_id"] }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
