{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arpg.dev/schemas/rules/unique_effects.v0.schema.json",
  "title": "Unique effect catalog (v0)",
  "type": "object",
  "required": ["version", "effects"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 0 },
    "effects": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["id", "enabled", "display_name", "summary", "hook", "compatible_item_types", "params", "status"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "enabled": { "type": "boolean" },
          "display_name": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "hook": {
            "type": "string",
            "enum": [
              "on_hero_damage_dealt",
              "on_basic_attack_hit",
              "on_equip_passive",
              "on_lethal_damage_taken",
              "on_block_or_evade",
              "on_enemy_killed",
              "on_skill_resource_shortfall",
              "on_large_hit_taken",
              "on_continuous_movement_attack",
              "on_projectile_hit_taken",
              "on_repeated_same_target_hit",
              "on_skill_damage_roll"
            ]
          },
          "compatible_item_types": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "params": {
            "type": "object",
            "additionalProperties": {
              "type": ["integer", "number", "string", "boolean"]
            }
          },
          "status": { "type": "string", "enum": ["ready", "disabled_seed"] }
        }
      }
    }
  }
}
