{
  "id": "gear_before_combat",
  "world_id": "gear_before_combat",
  "title": "Gear before combat",
  "description": "Walk to an initial sword, equip it, kill the reward dummy, pick up gold, and verify replay state.",
  "steps": [
    {
      "action": "walk_to_loot",
      "item_def_id": "rusty_sword"
    },
    {
      "action": "action_entity",
      "item_def_id": "rusty_sword",
      "event_type": "item_picked_up"
    },
    {
      "action": "equip_inventory_item",
      "item_def_id": "rusty_sword",
      "slot": "main_hand"
    },
    {
      "action": "walk_to_monster",
      "monster_def_id": "training_dummy_reward"
    },
    {
      "action": "action_until_event",
      "monster_def_id": "training_dummy_reward",
      "event_type": "monster_killed"
    },
    {
      "action": "wait_until_assertion",
      "assertion": { "type": "event_seen", "event_type": "gold_picked_up" },
      "timeout_s": 5
    }
  ],
  "assertions": [
    { "type": "inventory_count", "equals": 1 },
    { "type": "inventory_contains", "item_def_id": "rusty_sword", "equipped": true },
    { "type": "gold", "at_least": 6 },
    { "type": "monster_dead", "monster_def_id": "training_dummy_reward" }
  ]
}
