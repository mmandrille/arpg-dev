{
  "id": "teleporter_lab",
  "world_id": "dungeon_levels",
  "title": "Teleporter lab",
  "description": "Discover generated teleporters on level -1 and -2, then teleport back to level -1.",
  "steps": [
    { "action": "discover_teleporter", "max_ticks": 40 },
    { "action": "use_stair", "direction": "down", "max_ticks": 40 },
    { "action": "assert_teleporter_discovered", "level": -1, "discovered": true },
    { "action": "assert_teleporter_discovered", "level": -2, "discovered": false },
    { "action": "discover_teleporter", "max_ticks": 40 },
    { "action": "teleport_to_level", "target_level": -1 },
    { "action": "assert_player_at_discovered_teleporter", "level": -1, "tolerance": 0.001 }
  ],
  "assertions": [
    { "type": "current_level", "equals": -1 },
    { "type": "visited_levels_contain", "level": -2 },
    { "type": "teleporter_list_contains", "level": -1 },
    { "type": "teleporter_list_contains", "level": -2 },
    { "type": "teleporter_discovered", "level": -1, "discovered": true },
    { "type": "teleporter_discovered", "level": -2, "discovered": true },
    { "type": "event_seen", "event_type": "teleporter_discovered" },
    { "type": "event_seen", "event_type": "level_changed" }
  ],
  "visual": {
    "camera": { "x": 16, "y": 10, "zoom": 1.1 }
  }
}
