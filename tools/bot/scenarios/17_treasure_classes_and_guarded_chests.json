{
  "id": "treasure_classes_and_guarded_chests",
  "world_id": "dungeon_levels",
  "seed": "chest_seed_22",
  "title": "Treasure classes and guarded chests",
  "description": "Pinned dungeon seed generates a guarded chest floor: four dungeon mobs, one closed chest, multi-attempt mob loot, open-once chest loot, pickup, state, reconnect, replay, and fresh-session persistence.",
  "steps": [
    { "action": "use_stair", "direction": "down", "max_ticks": 40 },
    { "action": "assert_entity_count", "entity_type": "monster", "monster_def_id": "dungeon_mob", "equals": 4 },
    { "action": "assert_entity_count", "entity_type": "interactable", "interactable_def_id": "treasure_chest", "state": "closed", "equals": 1 },
    { "action": "kill_monsters", "monster_def_id": "dungeon_mob", "count": 4 },
    { "action": "action_entity", "interactable_def_id": "treasure_chest", "event_type": "interactable_activated" },
    { "action": "assert_entity_count", "entity_type": "interactable", "interactable_def_id": "treasure_chest", "state": "open", "equals": 1 },
    { "action": "action_entity", "interactable_def_id": "treasure_chest", "expect_reject": "invalid_target" },
    { "action": "pick_up_loot", "item_def_id": "cave_blade" },
    { "action": "assert_rolled_inventory_item", "item_def_id": "cave_blade", "item_template_id": "cave_blade", "stat_keys": ["damage_min", "damage_max"], "required_level": 1 }
  ],
  "assertions": [
    { "type": "current_level", "equals": -1 },
    { "type": "visited_levels_contain", "level": 0 },
    { "type": "entity_count", "entity_type": "monster", "monster_def_id": "dungeon_mob", "equals": 4 },
    { "type": "entity_count", "entity_type": "interactable", "interactable_def_id": "treasure_chest", "state": "open", "equals": 1 },
    { "type": "event_seen", "event_type": "monster_killed" },
    { "type": "event_seen", "event_type": "interactable_activated" },
    { "type": "event_seen", "event_type": "loot_dropped" },
    { "type": "inventory_contains", "item_def_id": "cave_blade", "equipped": false },
    { "type": "rolled_inventory_item", "item_def_id": "cave_blade", "item_template_id": "cave_blade", "equipped": false, "stat_keys": ["damage_min", "damage_max"], "required_level": 1 }
  ],
  "fresh_session_checks": [
    {
      "world_id": "dungeon_levels",
      "steps": [
        { "action": "assert_inventory_contains", "item_def_id": "cave_blade", "equipped": false },
        { "action": "assert_rolled_inventory_item", "item_def_id": "cave_blade", "item_template_id": "cave_blade", "equipped": false, "stat_keys": ["damage_min", "damage_max"], "required_level": 1 }
      ],
      "assertions": [
        { "type": "inventory_contains", "item_def_id": "cave_blade", "equipped": false },
        { "type": "rolled_inventory_item", "item_def_id": "cave_blade", "item_template_id": "cave_blade", "equipped": false, "stat_keys": ["damage_min", "damage_max"], "required_level": 1 }
      ]
    }
  ],
  "visual": {
    "camera": { "x": 16, "y": 10, "zoom": 1.1 }
  }
}
