{
  "id": "reachable_dungeon_obstacles",
  "world_id": "dungeon_levels",
  "seed": "v40_obstacles",
  "title": "Reachable dungeon obstacles",
  "description": "Descend into a pinned generated dungeon floor and prove authoritative interior walls are present, visible, and replay-stable.",
  "steps": [
    { "action": "use_stair", "direction": "down", "max_ticks": 120 },
    { "action": "wait_until_assertion", "assertion": { "type": "wall_count", "source": "generated", "at_least": 1 }, "timeout_s": 5 },
    { "action": "wait_until_assertion", "assertion": { "type": "wall_count", "kind": "water", "at_least": 1 }, "timeout_s": 5 },
    { "action": "wait_until_assertion", "assertion": { "type": "non_perimeter_wall_exists" }, "timeout_s": 5 },
    { "action": "action_entity", "interactable_def_id": "wooden_door", "event_type": "interactable_activated" }
  ],
  "assertions": [
    { "type": "current_level", "equals": -1 },
    { "type": "visited_levels_contain", "level": 0 },
    { "type": "visited_levels_contain", "level": -1 },
    { "type": "wall_count", "source": "generated", "at_least": 1 },
    { "type": "wall_count", "kind": "water", "at_least": 1 },
    { "type": "non_perimeter_wall_exists" },
    { "type": "interactable_state", "interactable_def_id": "wooden_door", "state": "open" },
    { "type": "event_seen", "event_type": "level_changed" }
  ],
  "visual": {
    "camera": { "x": 34, "y": 22, "zoom": 0.9 }
  }
}
