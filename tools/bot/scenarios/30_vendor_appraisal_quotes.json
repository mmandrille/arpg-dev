{
  "id": "vendor_appraisal_quotes",
  "ci_tier": "extended",
  "world_id": "vendor_lab",
  "seed": "town_vendor_gold_sink_1075",
  "title": "Vendor appraisal quotes",
  "description": "Open the compact vendor lab with inventory gear, verify server-authored item summaries/comparisons, then sell loot and buy a potion.",
  "steps": [
    {
      "action": "pick_up_first_rolled_loot"
    },
    {
      "action": "open_shop"
    },
    {
      "action": "assert_shop_offer_count",
      "shop_id": "town_vendor",
      "at_least": 3
    },
    {
      "action": "assert_shop_offer_details",
      "shop_id": "town_vendor",
      "offer_kind": "fixed",
      "equals": 2,
      "requires_category": true,
      "summary_contains": "Restores"
    },
    {
      "action": "assert_shop_offer_details",
      "shop_id": "town_vendor",
      "offer_kind": "generated",
      "at_least": 1,
      "requires_slot": true,
      "requires_category": true,
      "requires_comparison": true,
      "requires_requirement_status": true,
      "requires_equip_preview": true
    },
    {
      "action": "assert_shop_sell_appraisal_count",
      "shop_id": "town_vendor",
      "at_least": 1
    },
    {
      "action": "assert_shop_sell_appraisal_details",
      "shop_id": "town_vendor",
      "rolled": true,
      "at_least": 1,
      "requires_slot": true,
      "requires_category": true,
      "requires_comparison": true,
      "requires_requirement_status": true,
      "requires_equip_preview": true
    },
    {
      "action": "sell_inventory_item",
      "rolled": true,
      "equipped": false
    },
    {
      "action": "assert_gold_changed",
      "direction": "increase"
    },
    {
      "action": "buy_shop_offer",
      "offer_id": "fixed:red_potion"
    },
    {
      "action": "assert_gold_changed",
      "direction": "decrease"
    },
    {
      "action": "assert_shop_event",
      "event_type": "shop_opened",
      "at_least": 1
    },
    {
      "action": "assert_shop_event",
      "event_type": "shop_purchase",
      "at_least": 1
    },
    {
      "action": "assert_shop_event",
      "event_type": "shop_sale",
      "at_least": 1
    }
  ],
  "assertions": [
    {
      "type": "current_level",
      "equals": 0
    },
    {
      "type": "shop_offer_details",
      "shop_id": "town_vendor",
      "offer_kind": "generated",
      "at_least": 1,
      "requires_slot": true,
      "requires_category": true,
      "requires_comparison": true,
      "requires_requirement_status": true,
      "requires_equip_preview": true
    },
    {
      "type": "shop_sell_appraisal_details",
      "shop_id": "town_vendor",
      "at_least": 1,
      "requires_category": true,
      "summary_contains": "Restores"
    },
    {
      "type": "shop_event",
      "event_type": "shop_opened",
      "at_least": 1
    },
    {
      "type": "shop_event",
      "event_type": "shop_purchase",
      "at_least": 1
    },
    {
      "type": "shop_event",
      "event_type": "shop_sale",
      "at_least": 1
    }
  ],
  "visual": {
    "camera": {
      "x": 6,
      "y": 12,
      "zoom": 1.1
    }
  }
}
