{
  "id": "equipment_requirements_and_preview",
  "world_id": "requirements_lab",
  "seed": "facefeed00000043",
  "title": "Equipment requirements and preview",
  "description": "Pick up requirement-gated gear, prove server-authored requirement status and equip preview, reject unmet equip, then level and allocate STR to equip successfully.",
  "steps": [
    { "action": "pick_up_loot", "item_def_id": "cave_war_sword" },
    {
      "action": "assert_inventory_requirement_status",
      "item_def_id": "cave_war_sword",
      "requirements_met": false,
      "preview_slot": "main_hand",
      "preview_requirements_met": false,
      "preview_delta_stats": ["damage_max"],
      "status": [
        { "stat": "level", "required": 2, "current": 1, "met": false },
        { "stat": "str", "required": 6, "current": 5, "met": false }
      ]
    },
    { "action": "equip_inventory_item", "item_def_id": "cave_war_sword", "slot": "main_hand", "expect_reject": "requirements_not_met" },
    { "action": "kill_monsters", "monster_def_id": "dungeon_mob", "count": 4, "timeout_s": 30 },
    {
      "action": "assert_character_progression",
      "level": 2,
      "unspent_stat_points": 3,
      "str": 5
    },
    {
      "action": "allocate_stat",
      "stat": "str",
      "points": 1,
      "expect_progression": {
        "level": 2,
        "unspent_stat_points": 2,
        "str": 6
      }
    },
    {
      "action": "assert_inventory_requirement_status",
      "item_def_id": "cave_war_sword",
      "requirements_met": true,
      "preview_slot": "main_hand",
      "preview_requirements_met": true,
      "status": [
        { "stat": "level", "required": 2, "current": 2, "met": true },
        { "stat": "str", "required": 6, "current": 6, "met": true }
      ]
    },
    { "action": "equip_inventory_item", "item_def_id": "cave_war_sword", "slot": "main_hand" }
  ],
  "assertions": [
    { "type": "event_seen", "event_type": "character_leveled" },
    { "type": "event_seen", "event_type": "stat_allocated" },
    { "type": "character_progression", "level": 2, "unspent_stat_points": 2, "str": 6 },
    { "type": "equipped_slot_def", "slot": "main_hand", "item_def_id": "cave_war_sword" },
    {
      "type": "inventory_requirement_status",
      "item_def_id": "cave_war_sword",
      "equipped": true,
      "requirements_met": true,
      "preview_slot": "main_hand",
      "preview_requirements_met": true,
      "status": [
        { "stat": "level", "required": 2, "current": 2, "met": true },
        { "stat": "str", "required": 6, "current": 6, "met": true }
      ]
    }
  ],
