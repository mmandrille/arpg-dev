      "slot": "main_hand",
      "weapon_set": 0
    },
    {
      "action": "equip_inventory_item",
      "item_def_id": "cave_bow",
      "slot": "main_hand",
      "weapon_set": 1
    },
    {
      "action": "assert_active_weapon_set",
      "equals": 0
    },
    {
