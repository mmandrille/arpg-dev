{
  "id": "click_to_kill",
  "runner": "godot_client",
  "world_id": "vertical_slice",
  "title": "Click-to-kill: synthetic LMB on monster",
  "description": "Bot dispatches action_intent on the first monster until the authoritative monster_killed event arrives, then asserts entity removed from scene.",
  "client_steps": [
    { "type": "wait_ws_open",        "timeout_s": 10.0 },
    { "type": "wait_entity",         "entity_type": "monster", "timeout_s": 10.0 },
    { "type": "click_entity_until_event", "entity_type": "monster", "event_type": "monster_killed", "retry_s": 0.25, "timeout_s": 15.0 },
    { "type": "assert_entity_removed", "entity_type": "monster", "timeout_s": 5.0 }
  ]
}
