{
  "id": "use_potion_hotbar",
  "runner": "godot_client",
  "world_id": "heal_lab",
  "title": "Use potion hotbar: fight, loot two, drag + double-click + key 1",
  "description": "Bot kills training_dummy_heal, picks up two red potions, opens inventory, drags the second to hotbar slot 1, double-clicks the first for a partial heal, then presses KEY_1 to finish healing.",
  "client_steps": [
    { "type": "wait_ws_open", "timeout_s": 15.0 },
    { "type": "wait_entity", "entity_type": "monster", "timeout_s": 15.0 },
    { "type": "click_entity_until_event", "entity_type": "monster", "event_type": "monster_killed", "timeout_s": 20.0 },
    { "type": "wait_loot_count", "min_count": 2, "timeout_s": 15.0 },
    { "type": "click_entity", "entity_type": "loot", "entity_index": 0 },
    { "type": "wait_inventory_count", "item_def_id": "red_potion", "equals": 1, "timeout_s": 15.0 },
    { "type": "click_entity", "entity_type": "loot", "entity_index": 0 },
    { "type": "wait_inventory_count", "item_def_id": "red_potion", "equals": 2, "timeout_s": 15.0 },
    { "type": "press_key", "keycode": "KEY_I" },
    { "type": "assert_panel_visible", "visible": true },
    { "type": "assign_hotbar_slot", "slot_index": 0, "item_def_id": "red_potion", "bag_index": 1 },
    { "type": "assert_hotbar_assigned", "slot_index": 0, "item_def_id": "red_potion" },
    { "type": "double_click_bag_item", "item_def_id": "red_potion", "bag_index": 0 },
    { "type": "wait_event", "event_type": "player_healed", "timeout_s": 15.0 },
    { "type": "assert_player_hp", "equals": 9 },
    { "type": "assert_inventory_count", "item_def_id": "red_potion", "equals": 1 },
    { "type": "press_key", "keycode": "KEY_1" },
    { "type": "wait_event", "event_type": "player_healed", "timeout_s": 15.0 },
    { "type": "assert_player_hp", "equals": 10 },
    { "type": "assert_inventory_missing", "item_def_id": "red_potion" }
  ]
}
