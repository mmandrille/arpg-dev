    { "type": "wait_entity", "entity_type": "interactable", "timeout_s": 10.0 },
    { "type": "click_entity", "entity_type": "interactable", "interactable_def_id": "stairs_down" },
    { "type": "wait_wall_layout", "current_level": -2, "at_least": 5, "generated_at_least": 1, "non_perimeter_at_least": 1, "timeout_s": 15.0 },
    { "type": "assert_wall_layout", "current_level": -2, "generated_at_least": 1, "non_perimeter_at_least": 1 }
  ]
}
