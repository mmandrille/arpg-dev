    { "type": "wait_event", "event_type": "gold_picked_up", "timeout_s": 15.0 },
    { "type": "click_entity", "entity_type": "interactable", "interactable_def_id": "stairs_up" },
    { "type": "wait_event", "event_type": "level_changed", "to_level": 0, "timeout_s": 20.0 },
