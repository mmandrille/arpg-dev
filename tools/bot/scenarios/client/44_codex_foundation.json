        "create_game",
        "join_game",
        "codex",
        "settings",
        "exit"
      ]
    },
    {
      "type": "click_menu_button",
      "button": "codex"
    },
    {
      "type": "wait_codex_panel",
      "timeout_s": 3.0
    },
    {
      "type": "assert_codex_panel",
      "visible": true,
      "chapter_id": "concepts",
      "min_chapter_count": 3
    },
    {
      "type": "click_menu_button",
      "button": "back"
