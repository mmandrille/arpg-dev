{
  "id": "codex_foundation",
  "ci_tier": "extended",
  "runner": "godot_client",
  "world_id": "dungeon_levels",
  "title": "Codex foundation",
  "description": "Open the main-menu Codex and assert compiled class, item-family affinity, and resource mechanic pages.",
  "client_steps": [
    {
      "type": "wait_main_menu",
      "timeout_s": 10.0
    },
    {
      "type": "assert_main_menu_actions",
      "labels": [
        "Create Game",
        "Join Game",
        "Codex",
        "Settings",
        "Exit"
      ],
      "actions": [
        "create_game",
        "join_game",
        "codex",
        "settings",
        "exit"
      ]
    },
    {
      "type": "click_menu_button",
      "button": "codex"
    },
    {
      "type": "wait_codex_panel",
      "timeout_s": 3.0
    },
    {
      "type": "assert_codex_panel",
      "visible": true,
      "min_chapter_count": 6
    },
    {
      "type": "select_codex_page",
      "page_id": "class:barbarian"
    },
    {
      "type": "assert_codex_panel",
      "page_id": "class:barbarian",
      "page_title_contains": "Barbarian"
    },
    {
      "type": "select_codex_page",
      "page_id": "family:dagger"
    },
    {
      "type": "assert_codex_panel",
      "page_id": "family:dagger",
      "page_title_contains": "Dagger"
    },
    {
      "type": "select_codex_page",
      "page_id": "resource:upgrade_shard"
    },
    {
      "type": "assert_codex_panel",
      "page_id": "resource:upgrade_shard",
      "page_title_contains": "Upgrade Shard"
    },
    {
      "type": "select_codex_page",
      "page_id": "mechanic:treasure_classes"
    },
    {
      "type": "assert_codex_panel",
      "page_id": "mechanic:treasure_classes",
      "page_title_contains": "Treasure"
    },
    {
      "type": "click_menu_button",
      "button": "back"
    },
    {
      "type": "wait_main_menu",
      "timeout_s": 3.0
    }
  ]
}
