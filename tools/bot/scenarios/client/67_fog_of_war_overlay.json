{
  "id": "fog_of_war_overlay",
  "runner": "godot_client",
  "world_id": "dungeon_levels",
  "seed": "fog_of_war_overlay_seed",
  "title": "Fog of war overlay",
  "description": "Client renders world-space hero visibility from server-derived light radius and exposes bot debug radii.",
  "client_steps": [
    { "type": "wait_ws_open", "timeout_s": 10.0 },
    { "type": "wait_entity", "entity_type": "interactable", "timeout_s": 15.0 },
    { "type": "click_entity", "entity_type": "interactable", "interactable_def_id": "stairs_down" },
    { "type": "wait_wall_layout", "current_level": -1, "at_least": 1, "timeout_s": 15.0 },
    { "type": "set_camera_mode", "mode": "isometric" },
    { "type": "assert_character_progression", "derived_stats": { "light_radius": 9 } },
    {
      "type": "assert_fog_of_war",
      "enabled": true,
      "active": true,
      "hero_centered_falloff": true,
      "world_space_visibility": false,
      "light_radius": 9,
      "gloom_radius": 11.25,
      "organic_edge_enabled": true,
      "organic_edge_px_min": 5,
      "darkness_feather_px_min": 8,
      "organic_edge_segments": 18
    }
  ]
}
